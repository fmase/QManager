# Shell scripts must use LF line endings (deployed to Linux/OpenWRT)
# Catch-all: every .sh in this repo targets BusyBox/bash and must stay LF.
*.sh text eol=lf
# Extensionless scripts + nft rules that *.sh can't match:
scripts/**/*.nft text eol=lf
scripts/etc/init.d/* text eol=lf
scripts/etc/qmanager/* text eol=lf
scripts/usr/bin/* text eol=lf
# Binary override must come AFTER usr/bin/* so it wins:
scripts/usr/bin/bridge_traffic_monitor_rm551 binary

# Bundled prebuilt binaries (committed directly):
dependencies/sms_tool binary
dependencies/atcli_smd11 binary
