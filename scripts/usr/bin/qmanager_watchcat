#!/bin/sh
# =============================================================================
# qmanager_watchcat — QManager Connection Health Watchdog
# =============================================================================
# A pure state machine that monitors internet health by reading the ping
# daemon's output and executes tiered recovery actions when connectivity
# is lost. It NEVER pings on its own.
#
# States: MONITOR → SUSPECT → RECOVERY → COOLDOWN → (back to MONITOR)
#         LOCKED (maintenance mode — sleeps until lock removed)
#
# Escalation Tiers:
#   Tier 1: Restart WAN interface (ifdown/ifup)
#   Tier 2: Radio toggle (AT+CFUN=0/1) — skipped if tower lock active
#   Tier 3: SIM failover (AT+QUIMSLOT) — Golden Rule sequence
#   Tier 4: System reboot — token bucket: max N/hour, auto-disables
#
# Data flow:
#   Reads:  /tmp/qmanager_ping.json (from ping daemon)
#   Writes: /tmp/qmanager_watchcat.json (for poller consumption)
#           /tmp/qmanager_sim_failover (on Tier 3 success)
#           /tmp/qmanager_recovery_active (during any recovery)
#           /etc/qmanager/crash.log (Tier 4 reboot log)
#
# Install location: /usr/bin/qmanager_watchcat
# Dependencies: jq, qcmd, qlog.sh, events.sh
# =============================================================================

# --- Logging -----------------------------------------------------------------
. /usr/lib/qmanager/qlog.sh 2>/dev/null || {
    qlog_init() { :; }; qlog_debug() { :; }; qlog_info() { :; }
    qlog_warn() { :; }; qlog_error() { :; }; qlog_state_change() { :; }
}
qlog_init "watchcat"

# --- Events (for append_event) -----------------------------------------------
# Must define EVENTS_FILE and MAX_EVENTS before sourcing events.sh
EVENTS_FILE="/tmp/qmanager_events.json"
MAX_EVENTS=50
. /usr/lib/qmanager/events.sh 2>/dev/null || {
    append_event() { :; }
}

# --- File Paths --------------------------------------------------------------
PING_CACHE="/tmp/qmanager_ping.json"
STATE_FILE="/tmp/qmanager_watchcat.json"
STATE_TMP="/tmp/qmanager_watchcat.json.tmp"
PID_FILE="/tmp/qmanager_watchcat.pid"
RECOVERY_FLAG="/tmp/qmanager_recovery_active"
LOCK_FILE="/tmp/qmanager_watchcat.lock"
RELOAD_FLAG="/tmp/qmanager_watchcat_reload"
REVERT_FLAG="/tmp/qmanager_watchcat_revert_sim"
DISABLED_FLAG="/tmp/qmanager_watchcat_disabled"
SIM_FAILOVER_FILE="/tmp/qmanager_sim_failover"
LONG_RUNNING_FLAG="/tmp/qmanager_long_running"
PROFILE_APPLY_PID="/tmp/qmanager_profile_apply.pid"
TOWER_LOCK_CONFIG="/etc/qmanager/tower_lock.json"
CRASH_LOG="/etc/qmanager/crash.log"

# --- Configuration (defaults, overridden by UCI) -----------------------------
CFG_ENABLED=1
CFG_CHECK_INTERVAL=10
CFG_MAX_FAILURES=5
CFG_COOLDOWN=60
CFG_TIER1_ENABLED=1
CFG_TIER2_ENABLED=1
CFG_TIER3_ENABLED=0
CFG_TIER4_ENABLED=1
CFG_BACKUP_SIM_SLOT=""
CFG_MAX_REBOOTS_PER_HOUR=3
BOOT_SETTLE=30
PING_STALE_THRESHOLD=15
MODEM_WAIT_TIMEOUT=60

# --- State Variables ---------------------------------------------------------
state="monitor"
prev_state=""
failure_counter=0
current_tier=0
last_recovery_time="null"
last_recovery_tier="null"
total_recoveries=0
cooldown_remaining=0
sim_failover_active="false"
original_sim_slot="null"
current_sim_slot="null"
reboots_this_hour=0

# =============================================================================
# CONFIGURATION
# =============================================================================

read_config() {
    CFG_ENABLED=$(uci -q get quecmanager.watchcat.enabled 2>/dev/null)
    [ -z "$CFG_ENABLED" ] && CFG_ENABLED=1

    local val
    val=$(uci -q get quecmanager.watchcat.check_interval 2>/dev/null)
    [ -n "$val" ] && CFG_CHECK_INTERVAL="$val"

    val=$(uci -q get quecmanager.watchcat.max_failures 2>/dev/null)
    [ -n "$val" ] && CFG_MAX_FAILURES="$val"

    val=$(uci -q get quecmanager.watchcat.cooldown 2>/dev/null)
    [ -n "$val" ] && CFG_COOLDOWN="$val"

    val=$(uci -q get quecmanager.watchcat.tier1_enabled 2>/dev/null)
    [ -n "$val" ] && CFG_TIER1_ENABLED="$val"

    val=$(uci -q get quecmanager.watchcat.tier2_enabled 2>/dev/null)
    [ -n "$val" ] && CFG_TIER2_ENABLED="$val"

    val=$(uci -q get quecmanager.watchcat.tier3_enabled 2>/dev/null)
    [ -n "$val" ] && CFG_TIER3_ENABLED="$val"

    val=$(uci -q get quecmanager.watchcat.tier4_enabled 2>/dev/null)
    [ -n "$val" ] && CFG_TIER4_ENABLED="$val"

    val=$(uci -q get quecmanager.watchcat.backup_sim_slot 2>/dev/null)
    CFG_BACKUP_SIM_SLOT="$val"

    val=$(uci -q get quecmanager.watchcat.max_reboots_per_hour 2>/dev/null)
    [ -n "$val" ] && CFG_MAX_REBOOTS_PER_HOUR="$val"

    qlog_info "Config loaded: interval=${CFG_CHECK_INTERVAL}s max_fail=${CFG_MAX_FAILURES} cooldown=${CFG_COOLDOWN}s"
    qlog_info "  Tiers: T1=${CFG_TIER1_ENABLED} T2=${CFG_TIER2_ENABLED} T3=${CFG_TIER3_ENABLED} T4=${CFG_TIER4_ENABLED} backup_sim=${CFG_BACKUP_SIM_SLOT:-none}"
}

# =============================================================================
# STATE FILE WRITER
# =============================================================================

write_state() {
    local ts
    ts=$(date +%s)

    jq -n -c \
        --argjson ts "$ts" \
        --argjson enabled "$CFG_ENABLED" \
        --arg state "$state" \
        --argjson tier "$current_tier" \
        --argjson failures "$failure_counter" \
        --argjson last_time "${last_recovery_time:-null}" \
        --argjson last_tier "${last_recovery_tier:-null}" \
        --argjson total "$total_recoveries" \
        --argjson cooldown "$cooldown_remaining" \
        --argjson sf_active "$sim_failover_active" \
        --argjson sf_orig "${original_sim_slot:-null}" \
        --argjson sf_curr "${current_sim_slot:-null}" \
        --argjson reboots "$reboots_this_hour" \
        '{
            timestamp: $ts, enabled: ($enabled == 1),
            state: $state, current_tier: $tier,
            failure_count: $failures,
            last_recovery_time: $last_time,
            last_recovery_tier: $last_tier,
            total_recoveries: $total,
            cooldown_remaining: $cooldown,
            sim_failover_active: ($sf_active == "true"),
            original_sim_slot: $sf_orig,
            current_sim_slot: $sf_curr,
            reboots_this_hour: $reboots
        }' > "$STATE_TMP"

    mv "$STATE_TMP" "$STATE_FILE"
}

# =============================================================================
# HELPERS
# =============================================================================

# Check if maintenance mode is active (any lock condition)
check_locked() {
    # Explicit maintenance lock
    [ -f "$LOCK_FILE" ] && return 0

    # Long-running AT command (cell scan, firmware update)
    [ -f "$LONG_RUNNING_FLAG" ] && return 0

    # Profile apply in progress
    if [ -f "$PROFILE_APPLY_PID" ]; then
        local pid
        pid=$(cat "$PROFILE_APPLY_PID" 2>/dev/null)
        if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
            return 0
        fi
    fi

    return 1
}

# Check if tower lock is active (Tier 2 must be skipped)
tower_lock_active() {
    [ ! -f "$TOWER_LOCK_CONFIG" ] && return 1
    local lte_locked nr_locked
    lte_locked=$(jq -r '(.lte.enabled) | if . == null then "false" else tostring end' \
        "$TOWER_LOCK_CONFIG" 2>/dev/null)
    nr_locked=$(jq -r '(.nr_sa.enabled) | if . == null then "false" else tostring end' \
        "$TOWER_LOCK_CONFIG" 2>/dev/null)
    if [ "$lte_locked" = "true" ] || [ "$nr_locked" = "true" ]; then
        return 0
    fi
    return 1
}

# Read ping daemon data — returns 0 if valid, 1 if stale/missing
# Sets: ping_streak_fail, ping_reachable, ping_during_recovery
ping_streak_fail=0
ping_reachable="true"
ping_during_recovery="false"

read_ping() {
    if [ ! -f "$PING_CACHE" ]; then
        qlog_warn "Ping cache missing"
        return 1
    fi

    local _pdata
    _pdata=$(jq -r '[
        (.timestamp | if . == null then "0" else tostring end),
        ((.streak_fail) | if . == null then "0" else tostring end),
        ((.reachable) | if . == null then "true" else tostring end),
        ((.during_recovery) | if . == null then "false" else tostring end)
    ] | @tsv' "$PING_CACHE" 2>/dev/null)

    [ -z "$_pdata" ] && return 1

    local ping_ts
    ping_ts=$(printf '%s' "$_pdata" | cut -f1)
    ping_streak_fail=$(printf '%s' "$_pdata" | cut -f2)
    ping_reachable=$(printf '%s' "$_pdata" | cut -f3)
    ping_during_recovery=$(printf '%s' "$_pdata" | cut -f4)

    # Staleness check
    local now age
    now=$(date +%s)
    age=$((now - ping_ts))
    if [ "$age" -gt "$PING_STALE_THRESHOLD" ]; then
        qlog_warn "Ping data stale (age=${age}s), skipping cycle"
        return 1
    fi

    return 0
}

# Count reboots in the last hour from crash.log
count_recent_reboots() {
    if [ ! -f "$CRASH_LOG" ]; then
        reboots_this_hour=0
        return
    fi
    local now cutoff count
    now=$(date +%s)
    cutoff=$((now - 3600))
    count=$(awk -v cutoff="$cutoff" -F'|' '$1 >= cutoff { n++ } END { print n+0 }' "$CRASH_LOG" 2>/dev/null)
    reboots_this_hour="${count:-0}"
}

# Wait for modem to respond to AT commands after recovery action
wait_for_modem() {
    local elapsed=0
    while [ "$elapsed" -lt "$MODEM_WAIT_TIMEOUT" ]; do
        if qcmd 'AT' >/dev/null 2>&1; then
            qlog_info "Modem responsive after ${elapsed}s"
            return 0
        fi
        sleep 5
        elapsed=$((elapsed + 5))
    done
    qlog_error "Modem unresponsive after ${MODEM_WAIT_TIMEOUT}s"
    return 1
}

# =============================================================================
# RECOVERY TIERS
# =============================================================================

execute_tier1() {
    qlog_info "TIER 1: Restarting WAN interface"
    append_event "watchcat_recovery" "Watchcat: restarting WAN interface (Tier 1)" "warning"

    touch "$RECOVERY_FLAG"
    ifdown wan 2>/dev/null
    sleep 2
    ifup wan 2>/dev/null
    return 0
}

execute_tier2() {
    # Pre-check: tower lock
    if tower_lock_active; then
        qlog_warn "TIER 2 SKIPPED: tower lock active"
        return 1  # signal to skip this tier
    fi

    # Pre-check: long-running command
    if [ -f "$LONG_RUNNING_FLAG" ]; then
        qlog_warn "TIER 2 SKIPPED: long-running AT command active"
        return 1
    fi

    qlog_info "TIER 2: Toggling radio (AT+CFUN=0/1)"
    append_event "watchcat_recovery" "Watchcat: toggling radio (Tier 2)" "warning"

    touch "$RECOVERY_FLAG"

    local result
    result=$(qcmd 'AT+CFUN=0' 2>/dev/null)
    if [ $? -ne 0 ]; then
        qlog_error "TIER 2: AT+CFUN=0 failed"
        return 0  # action attempted, enter cooldown
    fi

    sleep 3

    qcmd 'AT+CFUN=1' >/dev/null 2>&1
    wait_for_modem
    return 0
}

execute_tier3() {
    # Pre-check: backup SIM configured
    if [ -z "$CFG_BACKUP_SIM_SLOT" ]; then
        qlog_warn "TIER 3 SKIPPED: no backup SIM slot configured"
        return 1
    fi

    # Read current SIM slot
    local current_slot_raw current_slot
    current_slot_raw=$(qcmd 'AT+QUIMSLOT?' 2>/dev/null)
    current_slot=$(printf '%s' "$current_slot_raw" | grep '+QUIMSLOT:' | sed 's/.*: *//' | tr -d '\r ')

    if [ -z "$current_slot" ]; then
        qlog_error "TIER 3: Cannot read current SIM slot"
        return 1
    fi

    if [ "$CFG_BACKUP_SIM_SLOT" = "$current_slot" ]; then
        qlog_warn "TIER 3 SKIPPED: backup slot ($CFG_BACKUP_SIM_SLOT) equals current slot ($current_slot)"
        return 1
    fi

    qlog_info "TIER 3: SIM failover from slot $current_slot to slot $CFG_BACKUP_SIM_SLOT"
    append_event "sim_failover" "Watchcat: switching to SIM slot $CFG_BACKUP_SIM_SLOT (Tier 3)" "warning"

    touch "$RECOVERY_FLAG"

    # Save original slot for potential fallback
    original_sim_slot="$current_slot"

    # Stop tower failover daemon (locks are meaningless on different SIM)
    /etc/init.d/qmanager_tower_failover stop 2>/dev/null

    # Golden Rule SIM swap sequence: CFUN=0 → 2s → QUIMSLOT → 2s → CFUN=1
    local result
    result=$(qcmd 'AT+CFUN=0' 2>/dev/null)
    if [ $? -ne 0 ]; then
        qlog_error "TIER 3: AT+CFUN=0 failed, aborting SIM failover"
        /etc/init.d/qmanager_tower_failover start 2>/dev/null
        return 0  # action attempted
    fi

    sleep 2

    qcmd "AT+QUIMSLOT=$CFG_BACKUP_SIM_SLOT" >/dev/null 2>&1
    sleep 2
    qcmd 'AT+CFUN=1' >/dev/null 2>&1

    # Wait for modem to come back
    if ! wait_for_modem; then
        qlog_error "TIER 3: Modem unresponsive after SIM switch, falling back"
        sim_failover_fallback
        return 0
    fi

    # Verify SIM presence
    local cpin_result
    cpin_result=$(qcmd 'AT+CPIN?' 2>/dev/null)
    if printf '%s' "$cpin_result" | grep -q 'ERROR'; then
        qlog_error "TIER 3: No SIM in backup slot $CFG_BACKUP_SIM_SLOT, falling back"
        sim_failover_fallback
        return 0
    fi

    # Read new ICCID for logging
    local new_iccid_raw new_iccid iccid_suffix
    new_iccid_raw=$(qcmd 'AT+QCCID' 2>/dev/null)
    new_iccid=$(printf '%s' "$new_iccid_raw" | grep '+QCCID:' | sed 's/+QCCID: //g' | tr -d '\r ')
    iccid_suffix=$(printf '%s' "$new_iccid" | tail -c 4)

    current_sim_slot="$CFG_BACKUP_SIM_SLOT"
    qlog_info "TIER 3: Switched to slot $CFG_BACKUP_SIM_SLOT (ICCID: ...$iccid_suffix)"

    # Don't write SIM failover state yet — wait for cooldown to verify connectivity
    # The cooldown handler will check reachability and finalize
    return 0
}

# Fallback: revert SIM to original slot
sim_failover_fallback() {
    qlog_warn "SIM failover fallback: reverting to slot $original_sim_slot"
    append_event "sim_failover" "Watchcat: backup SIM failed, reverting to slot $original_sim_slot" "warning"

    # Golden Rule sequence back to original
    qcmd 'AT+CFUN=0' >/dev/null 2>&1
    sleep 2
    qcmd "AT+QUIMSLOT=$original_sim_slot" >/dev/null 2>&1
    sleep 2
    qcmd 'AT+CFUN=1' >/dev/null 2>&1

    wait_for_modem

    # Auto-apply profile matching reverted SIM (watchdog_revert)
    local _rv_iccid_raw _rv_iccid _try
    _rv_iccid=""
    for _try in 1 2 3; do
        _rv_iccid_raw=$(qcmd 'AT+QCCID' 2>/dev/null)
        _rv_iccid=$(printf '%s' "$_rv_iccid_raw" | grep '+QCCID:' | sed 's/+QCCID: //g' | tr -d '\r ')
        [ -n "$_rv_iccid" ] && break
        sleep 1
    done
    if [ -n "$_rv_iccid" ]; then
        ( . /usr/lib/qmanager/profile_mgr.sh && auto_apply_profile "$_rv_iccid" "watchdog_revert" )
    else
        qlog_info "[watchdog_revert] ICCID query failed after revert, skipping auto-apply"
    fi

    # Restart tower failover daemon
    /etc/init.d/qmanager_tower_failover start 2>/dev/null

    current_sim_slot="$original_sim_slot"
    sim_failover_active="false"
    original_sim_slot="null"
}

execute_tier4() {
    # Token bucket check
    count_recent_reboots
    if [ "$reboots_this_hour" -ge "$CFG_MAX_REBOOTS_PER_HOUR" ]; then
        qlog_error "TIER 4: Reboot limit reached (${reboots_this_hour}/${CFG_MAX_REBOOTS_PER_HOUR} per hour)"
        qlog_error "TIER 4: Auto-disabling watchcat"
        append_event "watchcat_recovery" "Watchcat disabled: reboot limit exceeded (${reboots_this_hour} reboots/hour)" "error"

        # Permanently disable via UCI
        uci set quecmanager.watchcat.enabled=0
        uci commit quecmanager 2>/dev/null

        CFG_ENABLED=0
        state="disabled"
        touch "$DISABLED_FLAG"
        write_state
        rm -f "$RECOVERY_FLAG"

        # Exit — procd won't respawn since UCI disabled
        exit 0
    fi

    qlog_error "TIER 4: System reboot (recovery ${reboots_this_hour}/${CFG_MAX_REBOOTS_PER_HOUR})"
    append_event "watchcat_recovery" "Watchcat: rebooting system (Tier 4)" "error"

    # Log reboot to crash.log (persists across reboots)
    local ts
    ts=$(date +%s)
    echo "${ts}|reboot|tier4_escalation" >> "$CRASH_LOG"

    # Trim crash.log to last 20 entries
    if [ -f "$CRASH_LOG" ]; then
        local count
        count=$(wc -l < "$CRASH_LOG" 2>/dev/null || echo 0)
        if [ "$count" -gt 20 ]; then
            tail -n 20 "$CRASH_LOG" > "${CRASH_LOG}.tmp"
            mv "${CRASH_LOG}.tmp" "$CRASH_LOG"
        fi
    fi

    last_recovery_time="$ts"
    last_recovery_tier=4
    total_recoveries=$((total_recoveries + 1))
    write_state
    rm -f "$RECOVERY_FLAG"

    # Reboot after flushing state
    ( sleep 1 && reboot ) &
    exit 0
}

# =============================================================================
# ESCALATION ENGINE
# =============================================================================

# Find the next enabled tier >= start_tier. Returns 0 if found (sets
# current_tier), 1 if no tiers left.
find_next_tier() {
    local start="$1"
    local t="$start"

    while [ "$t" -le 4 ]; do
        case "$t" in
            1) [ "$CFG_TIER1_ENABLED" = "1" ] && { current_tier="$t"; return 0; } ;;
            2) [ "$CFG_TIER2_ENABLED" = "1" ] && { current_tier="$t"; return 0; } ;;
            3) [ "$CFG_TIER3_ENABLED" = "1" ] && { current_tier="$t"; return 0; } ;;
            4) [ "$CFG_TIER4_ENABLED" = "1" ] && { current_tier="$t"; return 0; } ;;
        esac
        t=$((t + 1))
    done
    return 1  # no enabled tiers remaining
}

do_recovery() {
    local action_result=0

    qlog_info "RECOVERY: Executing Tier $current_tier"
    touch "$RECOVERY_FLAG"

    case "$current_tier" in
        1) execute_tier1; action_result=$? ;;
        2) execute_tier2; action_result=$? ;;
        3) execute_tier3; action_result=$? ;;
        4) execute_tier4; action_result=$? ;;  # may not return (reboot/exit)
    esac

    # If tier was skipped (returned 1), try next tier
    if [ "$action_result" -ne 0 ]; then
        qlog_info "Tier $current_tier skipped, trying next"
        if find_next_tier $((current_tier + 1)); then
            do_recovery  # recurse with next tier
        else
            qlog_error "No more enabled tiers — all recovery options exhausted"
            rm -f "$RECOVERY_FLAG"
            state="monitor"
            current_tier=0
            failure_counter=0
        fi
        return
    fi

    # Recovery action executed — enter cooldown
    local ts
    ts=$(date +%s)
    last_recovery_time="$ts"
    last_recovery_tier="$current_tier"
    total_recoveries=$((total_recoveries + 1))
    cooldown_remaining="$CFG_COOLDOWN"
    state="cooldown"
    qlog_info "Entering COOLDOWN for ${CFG_COOLDOWN}s (after Tier $current_tier)"
}

# =============================================================================
# COOLDOWN COMPLETION
# =============================================================================

finish_cooldown() {
    rm -f "$RECOVERY_FLAG"

    # Re-read ping data to check if recovery worked
    if read_ping && [ "$ping_reachable" = "true" ]; then
        qlog_info "COOLDOWN complete: connectivity RESTORED after Tier $current_tier"

        # If this was Tier 3 SIM failover, finalize the failover state
        if [ "$current_tier" -eq 3 ] && [ "$current_sim_slot" != "$original_sim_slot" ] && [ "$original_sim_slot" != "null" ]; then
            sim_failover_active="true"

            # Read ICCIDs for the state file
            local orig_iccid curr_iccid_raw curr_iccid
            orig_iccid=""  # we don't have it cached
            curr_iccid_raw=$(qcmd 'AT+QCCID' 2>/dev/null)
            curr_iccid=$(printf '%s' "$curr_iccid_raw" | grep '+QCCID:' | sed 's/+QCCID: //g' | tr -d '\r ')

            local ts
            ts=$(date +%s)
            printf '{"active":true,"original_slot":%s,"current_slot":%s,"switched_at":%d,"reason":"connectivity_failure","original_iccid":"","current_iccid":"%s"}\n' \
                "$original_sim_slot" "$current_sim_slot" "$ts" "$curr_iccid" \
                > "$SIM_FAILOVER_FILE"

            qlog_info "SIM failover state saved: slot $original_sim_slot → $current_sim_slot"

            # Auto-apply profile matching new SIM (watchdog)
            if [ -n "$curr_iccid" ]; then
                ( . /usr/lib/qmanager/profile_mgr.sh && auto_apply_profile "$curr_iccid" "watchdog" )
            fi
        fi

        # Reset — connectivity recovered
        state="monitor"
        current_tier=0
        failure_counter=0
    else
        qlog_warn "COOLDOWN complete: connectivity NOT restored after Tier $current_tier"

        # If Tier 3 failed to restore connectivity, fall back
        if [ "$current_tier" -eq 3 ] && [ "$current_sim_slot" != "$original_sim_slot" ] && [ "$original_sim_slot" != "null" ]; then
            sim_failover_fallback
        fi

        # Escalate to next tier
        if find_next_tier $((current_tier + 1)); then
            state="suspect"
            failure_counter="$CFG_MAX_FAILURES"  # will trigger recovery immediately
            qlog_info "Escalating to Tier $current_tier"
        else
            qlog_error "All recovery tiers exhausted — returning to monitor"
            state="monitor"
            current_tier=0
            failure_counter=0
        fi
    fi
}

# =============================================================================
# USER-REQUESTED SIM REVERT
# =============================================================================

check_revert_request() {
    if [ -f "$REVERT_FLAG" ] && [ "$sim_failover_active" = "true" ]; then
        qlog_info "User requested SIM revert to slot $original_sim_slot"
        rm -f "$REVERT_FLAG"
        append_event "sim_failover" "Watchcat: reverting to original SIM slot $original_sim_slot (user request)" "info"

        touch "$RECOVERY_FLAG"
        sim_failover_fallback
        rm -f "$RECOVERY_FLAG" "$SIM_FAILOVER_FILE"

        sim_failover_active="false"
        state="monitor"
        current_tier=0
        failure_counter=0
        return 0
    fi
    rm -f "$REVERT_FLAG"  # clean up stale flag
    return 1
}

# =============================================================================
# MAIN LOOP
# =============================================================================

main() {
    # Prevent duplicate instances
    if [ -f "$PID_FILE" ]; then
        local old_pid
        old_pid=$(cat "$PID_FILE" 2>/dev/null)
        if [ -n "$old_pid" ] && kill -0 "$old_pid" 2>/dev/null; then
            qlog_error "Another watchcat already running (PID $old_pid), exiting"
            exit 1
        fi
        rm -f "$PID_FILE"
    fi
    echo $$ > "$PID_FILE"

    # Cleanup on exit
    trap 'rm -f "$PID_FILE" "$STATE_TMP" "$RECOVERY_FLAG"; write_state' EXIT INT TERM

    # Read configuration
    read_config

    if [ "$CFG_ENABLED" != "1" ]; then
        qlog_info "Watchcat disabled in config, exiting"
        exit 0
    fi

    qlog_info "========================================"
    qlog_info "QManager Watchcat starting (PID $$)"
    qlog_info "========================================"

    # Count reboots from crash.log (persisted across reboots)
    count_recent_reboots
    qlog_info "Reboots in last hour: $reboots_this_hour"

    # Check for stale SIM failover state from before reboot
    if [ -f "$SIM_FAILOVER_FILE" ]; then
        local sf_active_val
        sf_active_val=$(jq -r '(.active) | if . == null then "false" else tostring end' "$SIM_FAILOVER_FILE" 2>/dev/null)
        if [ "$sf_active_val" = "true" ]; then
            sim_failover_active="true"
            original_sim_slot=$(jq -r '(.original_slot) | if . == null then "null" else tostring end' "$SIM_FAILOVER_FILE" 2>/dev/null)
            current_sim_slot=$(jq -r '(.current_slot) | if . == null then "null" else tostring end' "$SIM_FAILOVER_FILE" 2>/dev/null)
            qlog_info "Resuming SIM failover state: slot $original_sim_slot → $current_sim_slot"
        fi
    fi

    # Boot settle — let modem and other daemons stabilize
    qlog_info "Boot settle: waiting ${BOOT_SETTLE}s"
    write_state
    sleep "$BOOT_SETTLE"

    # --- Main monitoring loop ---
    while true; do
        # Check for config reload request
        if [ -f "$RELOAD_FLAG" ]; then
            rm -f "$RELOAD_FLAG"
            qlog_info "Config reload requested"
            read_config
            if [ "$CFG_ENABLED" != "1" ]; then
                qlog_info "Watchcat disabled via config reload, exiting"
                state="disabled"
                write_state
                exit 0
            fi
        fi

        # Check for user SIM revert request
        check_revert_request

        # --- LOCKED state check ---
        if check_locked; then
            if [ "$state" != "locked" ]; then
                qlog_info "Entering LOCKED state (maintenance)"
                state="locked"
            fi
            write_state
            sleep "$CFG_CHECK_INTERVAL"
            continue
        fi

        # Exiting locked state
        if [ "$state" = "locked" ]; then
            qlog_info "Exiting LOCKED state"
            state="monitor"
            failure_counter=0
        fi

        # --- COOLDOWN state ---
        if [ "$state" = "cooldown" ]; then
            cooldown_remaining=$((cooldown_remaining - CFG_CHECK_INTERVAL))
            if [ "$cooldown_remaining" -le 0 ]; then
                cooldown_remaining=0
                finish_cooldown
            fi
            write_state
            sleep "$CFG_CHECK_INTERVAL"
            continue
        fi

        # --- Read ping data ---
        if ! read_ping; then
            # Stale or missing data — don't make recovery decisions
            write_state
            sleep "$CFG_CHECK_INTERVAL"
            continue
        fi

        # --- State machine ---
        case "$state" in
            monitor)
                if [ "$ping_streak_fail" -gt 0 ]; then
                    prev_state="$state"
                    state="suspect"
                    failure_counter=1
                    qlog_info "MONITOR → SUSPECT: streak_fail=$ping_streak_fail"
                fi
                ;;

            suspect)
                if [ "$ping_reachable" = "true" ] && [ "$ping_streak_fail" -eq 0 ]; then
                    # Naturally recovered
                    qlog_info "SUSPECT → MONITOR: connectivity restored naturally"
                    state="monitor"
                    failure_counter=0
                else
                    failure_counter=$((failure_counter + 1))
                    qlog_debug "SUSPECT: failure_counter=$failure_counter/$CFG_MAX_FAILURES"

                    if [ "$failure_counter" -ge "$CFG_MAX_FAILURES" ]; then
                        qlog_warn "SUSPECT → RECOVERY: threshold breached ($failure_counter >= $CFG_MAX_FAILURES)"
                        state="recovery"

                        # Find first enabled tier
                        if [ "$current_tier" -eq 0 ]; then
                            find_next_tier 1
                        fi

                        do_recovery
                    fi
                fi
                ;;

            recovery)
                # Should not stay here — do_recovery transitions to cooldown
                # If we're here, something went wrong
                qlog_warn "Unexpected RECOVERY state in main loop, resetting"
                state="monitor"
                failure_counter=0
                current_tier=0
                ;;
        esac

        write_state
        sleep "$CFG_CHECK_INTERVAL"
    done
}

main "$@"
