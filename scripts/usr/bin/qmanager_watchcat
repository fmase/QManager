#!/bin/sh
# =============================================================================
# qmanager_watchcat — QManager Connection Health Watchdog
# =============================================================================
# A pure state machine that monitors internet health by reading the ping
# daemon's output and executes tiered recovery actions when connectivity
# is lost. It NEVER pings on its own.
#
# States: MONITOR → SUSPECT → RECOVERY → COOLDOWN → (back to MONITOR)
#         LOCKED (maintenance mode — sleeps until lock removed)
#
# Escalation Tiers:
#   Tier 1: Network re-registration (AT+COPS=2 -> AT+COPS=0)
#   Tier 2: Radio toggle (AT+CFUN=0/1) — skipped if tower lock active
#   Tier 3: SIM failover (AT+QUIMSLOT) — Golden Rule sequence
#   Tier 4: System reboot — token bucket: max N/hour, auto-disables
#
# Data flow:
#   Reads:  /tmp/qmanager_ping.json (from ping daemon)
#   Writes: /tmp/qmanager_watchcat.json (for poller consumption)
#           /tmp/qmanager_sim_failover (on Tier 3 success)
#           /tmp/qmanager_recovery_active (during any recovery)
#           /etc/qmanager/crash.log (Tier 4 reboot log)
#
# Install location: /usr/bin/qmanager_watchcat
# Dependencies: jq, qcmd, qlog.sh, events.sh
# =============================================================================

# --- Logging -----------------------------------------------------------------
. /usr/lib/qmanager/qlog.sh 2>/dev/null || {
    qlog_init() { :; }; qlog_debug() { :; }; qlog_info() { :; }
    qlog_warn() { :; }; qlog_error() { :; }; qlog_state_change() { :; }
}
qlog_init "watchcat"

# --- Events (for append_event) -----------------------------------------------
# Must define EVENTS_FILE and MAX_EVENTS before sourcing events.sh
EVENTS_FILE="/tmp/qmanager_events.json"
MAX_EVENTS=50
. /usr/lib/qmanager/events.sh 2>/dev/null || {
    append_event() { :; }
}

# --- Known-SIMs database (for sim_db_add on SIM revert/failover) -------------
. /usr/lib/qmanager/sim_db.sh 2>/dev/null || {
    sim_db_add() { :; }
}

# --- File Paths --------------------------------------------------------------
PING_CACHE="/tmp/qmanager_ping.json"
STATE_FILE="/tmp/qmanager_watchcat.json"
STATE_TMP="/tmp/qmanager_watchcat.json.tmp"
PID_FILE="/tmp/qmanager_watchcat.pid"
RECOVERY_FLAG="/tmp/qmanager_recovery_active"
LOCK_FILE="/tmp/qmanager_watchcat.lock"
RELOAD_FLAG="/tmp/qmanager_watchcat_reload"
REVERT_FLAG="/tmp/qmanager_watchcat_revert_sim"
DISABLED_FLAG="/tmp/qmanager_watchcat_disabled"
SIM_FAILOVER_FILE="/tmp/qmanager_sim_failover"
LONG_RUNNING_FLAG="/tmp/qmanager_long_running"
PROFILE_APPLY_PID="/tmp/qmanager_profile_apply.pid"
TOWER_LOCK_CONFIG="/etc/qmanager/tower_lock.json"
CRASH_LOG="/etc/qmanager/crash.log"

# --- Configuration (defaults, overridden by UCI) -----------------------------
CFG_ENABLED=1
CFG_CHECK_INTERVAL=10
CFG_FAIL_THRESHOLD=5          # consecutive failed PROBES (raw ping streak_fail) before recovery
CFG_COOLDOWN=60
CFG_TIER1_ENABLED=1
CFG_TIER2_ENABLED=1
CFG_TIER3_ENABLED=0
CFG_TIER4_ENABLED=1
CFG_BACKUP_SIM_SLOT=""
CFG_MAX_REBOOTS_PER_HOUR=3
CFG_QUALITY_ENABLED=0
# Shared degraded thresholds resolved from quecmanager.quality_thresholds.*
# (NOT watchcat.* — the retired latency_ceiling_ms/loss_ceiling_pct keys). These
# are recomputed by resolve_quality_thresholds() on each config load/reload.
CFG_LATENCY_THRESHOLD_MS=250
CFG_LOSS_THRESHOLD_PCT=30
CFG_QUALITY_CONSECUTIVE=5
CFG_SSR_AWARE=1
CFG_SSR_GRACE=45
STATUS_CACHE="/tmp/qmanager_status.json"
STATUS_STALE_THRESHOLD=30
BOOT_SETTLE=30
PING_STALE_THRESHOLD=15
MODEM_WAIT_TIMEOUT=60

# --- State Variables ---------------------------------------------------------
state="monitor"
prev_state=""
failure_counter=0
current_tier=0
last_recovery_time="null"
last_recovery_tier="null"
total_recoveries=0
cooldown_remaining=0
sim_failover_active="false"
original_sim_slot="null"
current_sim_slot="null"
reboots_this_hour=0
cooldown_stale_retries=0
quality_breach_counter=0
recovery_reason="unreachable"   # "unreachable" | "quality" — why current/last recovery fired
_recovery_marker_emitted=""     # "<tier>-<reason>" of the last emitted start marker; "" = none this episode
ssr_hold="false"          # JSON bool literal for write_state
last_ssr_detected="null"  # JSON null literal or monotonic-seconds integer
ssr_hold_started=0        # monotonic seconds-since-boot when hold began; 0 = not holding

# =============================================================================
# CONFIGURATION
# =============================================================================

read_config() {
    CFG_ENABLED=$(uci -q get quecmanager.watchcat.enabled 2>/dev/null)
    [ -z "$CFG_ENABLED" ] && CFG_ENABLED=1

    local val
    val=$(uci -q get quecmanager.watchcat.check_interval 2>/dev/null)
    [ -n "$val" ] && CFG_CHECK_INTERVAL="$val"

    # fail_threshold = consecutive failed PROBES (raw ping streak_fail). Renamed
    # from the retired max_failures (which counted watchcat's own loop cycles).
    # Default 5 if absent so an un-migrated install still works immediately.
    val=$(uci -q get quecmanager.watchcat.fail_threshold 2>/dev/null)
    case "$val" in ''|*[!0-9]*) CFG_FAIL_THRESHOLD=5 ;; *) CFG_FAIL_THRESHOLD="$val" ;; esac

    val=$(uci -q get quecmanager.watchcat.cooldown 2>/dev/null)
    [ -n "$val" ] && CFG_COOLDOWN="$val"

    val=$(uci -q get quecmanager.watchcat.tier1_enabled 2>/dev/null)
    [ -n "$val" ] && CFG_TIER1_ENABLED="$val"

    val=$(uci -q get quecmanager.watchcat.tier2_enabled 2>/dev/null)
    [ -n "$val" ] && CFG_TIER2_ENABLED="$val"

    val=$(uci -q get quecmanager.watchcat.tier3_enabled 2>/dev/null)
    [ -n "$val" ] && CFG_TIER3_ENABLED="$val"

    val=$(uci -q get quecmanager.watchcat.tier4_enabled 2>/dev/null)
    [ -n "$val" ] && CFG_TIER4_ENABLED="$val"

    val=$(uci -q get quecmanager.watchcat.backup_sim_slot 2>/dev/null)
    CFG_BACKUP_SIM_SLOT="$val"

    val=$(uci -q get quecmanager.watchcat.max_reboots_per_hour 2>/dev/null)
    [ -n "$val" ] && CFG_MAX_REBOOTS_PER_HOUR="$val"

    CFG_QUALITY_ENABLED=$(uci -q get quecmanager.watchcat.quality_enabled 2>/dev/null)
    [ -z "$CFG_QUALITY_ENABLED" ] && CFG_QUALITY_ENABLED=0

    # Degraded thresholds are now SHARED with the poller: read from
    # quecmanager.quality_thresholds.* (latency_ceiling_ms / loss_ceiling_pct on
    # watchcat.* are retired and intentionally NOT read here).
    resolve_quality_thresholds

    val=$(uci -q get quecmanager.watchcat.quality_consecutive 2>/dev/null)
    [ -n "$val" ] && CFG_QUALITY_CONSECUTIVE="$val"

    CFG_SSR_AWARE=$(uci -q get quecmanager.watchcat.ssr_aware 2>/dev/null)
    [ -z "$CFG_SSR_AWARE" ] && CFG_SSR_AWARE=1

    val=$(uci -q get quecmanager.watchcat.ssr_grace 2>/dev/null)
    [ -n "$val" ] && CFG_SSR_GRACE="$val"

    qlog_info "Config loaded: interval=${CFG_CHECK_INTERVAL}s fail_threshold=${CFG_FAIL_THRESHOLD} probes cooldown=${CFG_COOLDOWN}s"
    qlog_info "  Tiers: T1=${CFG_TIER1_ENABLED} T2=${CFG_TIER2_ENABLED} T3=${CFG_TIER3_ENABLED} T4=${CFG_TIER4_ENABLED} backup_sim=${CFG_BACKUP_SIM_SLOT:-none}"
    qlog_info "  Quality: enabled=${CFG_QUALITY_ENABLED} latency=${CFG_LATENCY_THRESHOLD_MS}ms loss=${CFG_LOSS_THRESHOLD_PCT}% consecutive=${CFG_QUALITY_CONSECUTIVE} (shared thresholds)"
    qlog_info "  SSR-aware: enabled=${CFG_SSR_AWARE} grace=${CFG_SSR_GRACE}s"
}

# Resolve the SHARED degraded thresholds from quecmanager.quality_thresholds.*
# into CFG_LATENCY_THRESHOLD_MS / CFG_LOSS_THRESHOLD_PCT. This is the watchdog's
# local mirror of the poller's resolver (kept in-daemon rather than a new lib —
# only two consumers, and the watchdog must not depend on poller globals). The
# section's ABSENCE means "default" -> tolerant/tolerant (250ms / 30%), matching
# the poller. `custom` reads the latency_custom_ms / loss_custom_pct keys; a
# non-numeric/empty custom value falls back to the tolerant default so a
# half-written UCI never yields an empty comparison value.
resolve_quality_thresholds() {
    local _lat_preset
    local _loss_preset
    local _lat_custom
    local _loss_custom

    _lat_preset=$(uci -q get quecmanager.quality_thresholds.latency_preset 2>/dev/null)
    _loss_preset=$(uci -q get quecmanager.quality_thresholds.loss_preset 2>/dev/null)

    case "$_lat_preset" in
        standard)      CFG_LATENCY_THRESHOLD_MS=150 ;;
        very-tolerant) CFG_LATENCY_THRESHOLD_MS=500 ;;
        custom)
            _lat_custom=$(uci -q get quecmanager.quality_thresholds.latency_custom_ms 2>/dev/null)
            case "$_lat_custom" in
                ''|*[!0-9]*) CFG_LATENCY_THRESHOLD_MS=250 ;;
                *)           CFG_LATENCY_THRESHOLD_MS="$_lat_custom" ;;
            esac
            ;;
        tolerant|*)    CFG_LATENCY_THRESHOLD_MS=250 ;;
    esac

    case "$_loss_preset" in
        standard)      CFG_LOSS_THRESHOLD_PCT=15 ;;
        very-tolerant) CFG_LOSS_THRESHOLD_PCT=50 ;;
        custom)
            _loss_custom=$(uci -q get quecmanager.quality_thresholds.loss_custom_pct 2>/dev/null)
            case "$_loss_custom" in
                ''|*[!0-9]*) CFG_LOSS_THRESHOLD_PCT=30 ;;
                *)           CFG_LOSS_THRESHOLD_PCT="$_loss_custom" ;;
            esac
            ;;
        tolerant|*)    CFG_LOSS_THRESHOLD_PCT=30 ;;
    esac
}

# =============================================================================
# STATE FILE WRITER
# =============================================================================

write_state() {
    local ts
    ts=$(date +%s)

    jq -n -c \
        --argjson ts "$ts" \
        --argjson enabled "$CFG_ENABLED" \
        --arg state "$state" \
        --argjson tier "$current_tier" \
        --argjson failures "$failure_counter" \
        --argjson last_time "${last_recovery_time:-null}" \
        --argjson last_tier "${last_recovery_tier:-null}" \
        --argjson total "$total_recoveries" \
        --argjson cooldown "$cooldown_remaining" \
        --argjson sf_active "$sim_failover_active" \
        --argjson sf_orig "${original_sim_slot:-null}" \
        --argjson sf_curr "${current_sim_slot:-null}" \
        --argjson reboots "$reboots_this_hour" \
        --argjson quality_breach "$quality_breach_counter" \
        --argjson quality_enabled "$CFG_QUALITY_ENABLED" \
        --arg recovery_reason "$recovery_reason" \
        --argjson ssr_hold "$ssr_hold" \
        --argjson last_ssr_detected "$last_ssr_detected" \
        '{
            timestamp: $ts, enabled: ($enabled == 1),
            state: $state, current_tier: $tier,
            failure_count: $failures,
            last_recovery_time: $last_time,
            last_recovery_tier: $last_tier,
            total_recoveries: $total,
            cooldown_remaining: $cooldown,
            sim_failover_active: ($sf_active == "true"),
            original_sim_slot: $sf_orig,
            current_sim_slot: $sf_curr,
            reboots_this_hour: $reboots,
            quality_breach_count: $quality_breach,
            quality_enabled: ($quality_enabled == 1),
            last_recovery_reason: $recovery_reason,
            ssr_hold: $ssr_hold,
            last_ssr_detected: $last_ssr_detected
        }' > "$STATE_TMP"

    mv "$STATE_TMP" "$STATE_FILE"
}

# =============================================================================
# HELPERS
# =============================================================================

# Check if maintenance mode is active (any lock condition)
check_locked() {
    # Explicit maintenance lock
    [ -f "$LOCK_FILE" ] && return 0

    # Long-running AT command (cell scan, firmware update)
    [ -f "$LONG_RUNNING_FLAG" ] && return 0

    # Profile apply in progress
    if [ -f "$PROFILE_APPLY_PID" ]; then
        local pid
        pid=$(cat "$PROFILE_APPLY_PID" 2>/dev/null)
        if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
            return 0
        fi
    fi

    return 1
}

# Check if tower lock is active (Tier 2 must be skipped)
tower_lock_active() {
    [ ! -f "$TOWER_LOCK_CONFIG" ] && return 1
    local lte_locked
    local nr_locked
    lte_locked=$(jq -r '(.lte.enabled) | if . == null then "false" else tostring end' \
        "$TOWER_LOCK_CONFIG" 2>/dev/null)
    nr_locked=$(jq -r '(.nr_sa.enabled) | if . == null then "false" else tostring end' \
        "$TOWER_LOCK_CONFIG" 2>/dev/null)
    if [ "$lte_locked" = "true" ] || [ "$nr_locked" = "true" ]; then
        return 0
    fi
    return 1
}

# Read ping daemon data — returns 0 if valid, 1 if stale/missing
# Sets: ping_streak_fail, ping_reachable, ping_during_recovery
ping_streak_fail=0
ping_reachable="true"
ping_during_recovery="false"

read_ping() {
    if [ ! -f "$PING_CACHE" ]; then
        qlog_warn "Ping cache missing"
        return 1
    fi

    local _pdata
    _pdata=$(jq -r '[
        (.timestamp | if . == null then "0" else tostring end),
        ((.streak_fail) | if . == null then "0" else tostring end),
        ((.reachable) | if . == null then "true" else tostring end),
        ((.during_recovery) | if . == null then "false" else tostring end)
    ] | @tsv' "$PING_CACHE" 2>/dev/null)

    [ -z "$_pdata" ] && return 1

    local ping_ts
    ping_ts=$(printf '%s' "$_pdata" | cut -f1)
    ping_streak_fail=$(printf '%s' "$_pdata" | cut -f2)
    ping_reachable=$(printf '%s' "$_pdata" | cut -f3)
    ping_during_recovery=$(printf '%s' "$_pdata" | cut -f4)

    # Staleness check
    local now
    local age
    now=$(date +%s)
    age=$((now - ping_ts))
    if [ "$age" -gt "$PING_STALE_THRESHOLD" ]; then
        qlog_warn "Ping data stale (age=${age}s), skipping cycle"
        return 1
    fi

    return 0
}

# Read poller status.json for connection-quality metrics, with a staleness
# guard. The .connectivity object has no timestamp of its own, so freshness
# is judged from the ROOT .timestamp. Returns 0 if FRESH+valid, 1 if
# stale/missing/unparseable (= NO-SIGNAL).
# Sets: q_avg_latency (may be "null"), q_packet_loss (sanitized int)
q_avg_latency="null"
q_packet_loss="0"
read_quality() {
    [ -f "$STATUS_CACHE" ] || return 1
    local _qdata
    _qdata=$(jq -r '[
        (.timestamp | if . == null then "0" else tostring end),
        (.connectivity.avg_latency_ms | if . == null then "null" else tostring end),
        (.connectivity.packet_loss_pct | if . == null then "0" else tostring end)
    ] | @tsv' "$STATUS_CACHE" 2>/dev/null)
    [ -z "$_qdata" ] && return 1
    local _ts
    _ts=$(printf '%s' "$_qdata" | cut -f1)
    q_avg_latency=$(printf '%s' "$_qdata" | cut -f2)
    q_packet_loss=$(printf '%s' "$_qdata" | cut -f3)
    # sanitize loss to a clean integer (avg_latency may legitimately be "null")
    case "$q_packet_loss" in ''|*[!0-9]*) q_packet_loss=0 ;; esac
    local _now
    local _age
    _now=$(date +%s)
    _age=$((_now - _ts))
    if [ "$_ts" -le 0 ] 2>/dev/null || [ "$_age" -gt "$STATUS_STALE_THRESHOLD" ]; then
        qlog_warn "Quality data stale (age=${_age}s) — treating as no-signal"
        return 1
    fi
    return 0
}

# Decide whether current quality (already read by read_quality) breaches the
# configured ceilings. OR logic; a ceiling of 0 means IGNORE that metric.
# avg_latency_ms is a FLOAT — comparison MUST use awk (BusyBox [ -gt ] errors
# on decimals). Returns 0 if breached, 1 if not.
quality_breached() {
    # latency: only if threshold > 0 AND we have a numeric windowed average
    if [ "$CFG_LATENCY_THRESHOLD_MS" -gt 0 ] 2>/dev/null && [ "$q_avg_latency" != "null" ]; then
        if awk -v a="$q_avg_latency" -v c="$CFG_LATENCY_THRESHOLD_MS" 'BEGIN{ exit !((a+0) > (c+0)) }'; then
            qlog_warn "QUALITY breach: avg latency ${q_avg_latency}ms > ${CFG_LATENCY_THRESHOLD_MS}ms (shared)"
            return 0
        fi
    fi
    # loss: only if threshold > 0
    if [ "$CFG_LOSS_THRESHOLD_PCT" -gt 0 ] 2>/dev/null; then
        if [ "$q_packet_loss" -ge "$CFG_LOSS_THRESHOLD_PCT" ] 2>/dev/null; then
            qlog_warn "QUALITY breach: loss ${q_packet_loss}% >= ${CFG_LOSS_THRESHOLD_PCT}% (shared)"
            return 0
        fi
    fi
    return 1
}

# Accrue the consecutive-breach counter and, on reaching the threshold, kick
# off the SAME Tier 1->4 recovery ladder used by the reachability path.
# Returns 0 if it TRIGGERED recovery this cycle (caller skips rest of cycle),
# 1 otherwise.
evaluate_quality() {
    [ "$CFG_QUALITY_ENABLED" = "1" ] || return 1
    if ! read_quality; then
        # no-signal: leave counter unchanged (never count as breach, never reset)
        return 1
    fi
    if quality_breached; then
        quality_breach_counter=$((quality_breach_counter + 1))
        qlog_info "QUALITY: breach ${quality_breach_counter}/${CFG_QUALITY_CONSECUTIVE} (avg ${q_avg_latency}ms vs ${CFG_LATENCY_THRESHOLD_MS}ms, loss ${q_packet_loss}% vs ${CFG_LOSS_THRESHOLD_PCT}%)"
        if [ "$quality_breach_counter" -ge "$CFG_QUALITY_CONSECUTIVE" ]; then
            qlog_warn "QUALITY → RECOVERY: ${CFG_QUALITY_CONSECUTIVE} consecutive breaches (avg ${q_avg_latency}ms / loss ${q_packet_loss}% vs ${CFG_LATENCY_THRESHOLD_MS}ms / ${CFG_LOSS_THRESHOLD_PCT}%)"
            append_event "watchcat_recovery" "Watchcat: connection quality degraded (latency ${q_avg_latency}ms / loss ${q_packet_loss}%) — starting recovery" "warning"
            quality_breach_counter=0
            recovery_reason="quality"

            # SSR-aware hold: if a recoverable baseband SSR is mid-flight, hold
            # the ladder this cycle rather than forcing a detach. Not the main
            # loop here — return from evaluate_quality so do_recovery is skipped;
            # the main loop's write_state + sleep proceed normally.
            if ssr_hold_gate; then
                state="ssr_hold"
                return 0
            fi

            state="recovery"
            if [ "$current_tier" -eq 0 ]; then
                find_next_tier 1
            fi
            do_recovery
            return 0
        fi
    else
        quality_breach_counter=0
    fi
    return 1
}

# Count reboots in the last hour from crash.log
count_recent_reboots() {
    if [ ! -f "$CRASH_LOG" ]; then
        reboots_this_hour=0
        return
    fi
    local now
    local cutoff
    local count
    now=$(date +%s)
    cutoff=$((now - 3600))
    count=$(awk -v cutoff="$cutoff" -F'|' '$1 >= cutoff { n++ } END { print n+0 }' "$CRASH_LOG" 2>/dev/null)
    reboots_this_hour="${count:-0}"
}

# --- SSR (baseband subsystem restart) awareness ---------------------------
# The RM551E periodically suffers RECOVERABLE Qualcomm MPSS baseband SSRs: the
# kernel logs "4080000.remoteproc-mss: fatal error received" then brings the
# remoteproc back up ~3-4s later, with the data path restored in ~10-25s. If
# watchcat fires its recovery ladder (forced AT+COPS / AT+CFUN detach) WHILE the
# baseband is mid-self-heal, it amplifies a ~30-60s self-healing outage into a
# multi-minute thrash. This gate detects an in-progress SSR and HOLDS the ladder
# for a grace window, only falling through to the normal ladder if connectivity
# does not return (the genuine stuck / AP-hang case).

# Best-effort read-only check of the kernel ring buffer for a RECENT MPSS crash.
# Returns 0 (true) if a fatal-error line exists AND it is within CFG_SSR_GRACE
# seconds of now; 1 (false) otherwise — including when dmesg yields nothing, the
# crash line was evicted, or the timestamp fails to parse (graceful degradation:
# absence of evidence is NOT evidence of absence; we never block recovery on it).
# dmesg timestamps are monotonic seconds-since-boot floats like "[ 12345.678901]"
# (BusyBox dmesg has no -T / -l); we parse integer seconds only and compare to
# /proc/uptime. Calls dmesg ONCE per invocation (only at an escalation decision).
ssr_in_progress() {
    [ "$CFG_SSR_AWARE" = "1" ] || return 1

    local crash_line
    local crash_ts
    local now

    crash_line=$(dmesg 2>/dev/null | grep "4080000.remoteproc-mss: fatal error received" | tail -n 1)
    [ -n "$crash_line" ] || return 1

    # Extract leading integer seconds from the dmesg monotonic timestamp. Real
    # lines on this kernel are double-bracketed: "[ 12345.678901][ T8033] msg"
    # (CONFIG_PRINTK_CALLER); the older single-bracket "[ 12345.678901] msg" also
    # works. sed (not awk -F) because BusyBox awk 1.36.1 rejects a bracket-class
    # field separator as an "Unknown collating element" — verified on-device.
    crash_ts=$(printf '%s' "$crash_line" | sed 's/^\[[ ]*\([0-9]*\)\..*/\1/')
    case "$crash_ts" in ''|*[!0-9]*) return 1 ;; esac

    now=$(cut -d. -f1 /proc/uptime 2>/dev/null)
    case "$now" in ''|*[!0-9]*) return 1 ;; esac

    local delta
    delta=$((now - crash_ts))
    [ "$delta" -ge 0 ] && [ "$delta" -le "$CFG_SSR_GRACE" ] && return 0
    return 1
}

# Decide whether to HOLD the recovery ladder this cycle. Returns 0 to HOLD
# (caller skips do_recovery and lets the modem self-heal), 1 to PROCEED to the
# normal ladder. Sits BELOW all existing guards (LOCKED, cooldown, revert) and
# only intercepts at the do_recovery initiation sites.
ssr_hold_gate() {
    local now
    local held

    # Already holding? Check whether the grace window expired.
    if [ "$ssr_hold" = "true" ]; then
        now=$(cut -d. -f1 /proc/uptime 2>/dev/null)
        case "$now" in ''|*[!0-9]*) now=0 ;; esac
        held=$((now - ssr_hold_started))
        if [ "$held" -ge "$CFG_SSR_GRACE" ]; then
            qlog_warn "SSR-hold grace (${CFG_SSR_GRACE}s) expired without recovery; releasing to ladder"
            ssr_hold="false"
            ssr_hold_started=0
            return 1   # fall through to the normal ladder (genuine stuck case)
        fi
        return 0       # keep holding
    fi

    # Not yet holding — start a hold only if an SSR is detectable right now.
    if ssr_in_progress; then
        now=$(cut -d. -f1 /proc/uptime 2>/dev/null)
        case "$now" in ''|*[!0-9]*) now=0 ;; esac
        ssr_hold="true"
        ssr_hold_started="$now"
        last_ssr_detected="$now"   # monotonic seconds; UI surfaces "self-recovery"
        qlog_warn "Recoverable baseband SSR detected; holding recovery ladder up to ${CFG_SSR_GRACE}s for self-heal"
        append_event "watchcat_recovery" "Watchcat: recoverable baseband restart detected — holding recovery to let the modem self-heal" "info"
        return 0
    fi
    return 1
}

# Clear an SSR hold on natural recovery (connectivity returned on its own — the
# expected happy path; we did nothing harmful). Idempotent.
ssr_hold_clear() {
    if [ "$ssr_hold" = "true" ]; then
        qlog_info "SSR-hold cleared: connectivity recovered naturally"
    fi
    ssr_hold="false"
    ssr_hold_started=0
}

# Wait for modem to respond to AT commands after recovery action
wait_for_modem() {
    local elapsed=0
    while [ "$elapsed" -lt "$MODEM_WAIT_TIMEOUT" ]; do
        if qcmd 'AT' >/dev/null 2>&1; then
            qlog_info "Modem responsive after ${elapsed}s"
            return 0
        fi
        sleep 5
        elapsed=$((elapsed + 5))
    done
    qlog_error "Modem unresponsive after ${MODEM_WAIT_TIMEOUT}s"
    return 1
}

# =============================================================================
# RECOVERY TIERS
# =============================================================================

execute_tier1() {
    qlog_info "TIER 1: Network re-registration (AT+COPS=2 -> AT+COPS=0)"
    append_event "watchcat_recovery" "Watchcat: re-registering on network (Tier 1)" "warning"

    touch "$RECOVERY_FLAG"
    qcmd 'AT+COPS=2' >/dev/null 2>&1
    sleep 2
    qcmd 'AT+COPS=0' >/dev/null 2>&1
    return 0
}

execute_tier2() {
    # Pre-check: tower lock
    if tower_lock_active; then
        qlog_warn "TIER 2 SKIPPED: tower lock active"
        return 1  # signal to skip this tier
    fi

    # Pre-check: long-running command
    if [ -f "$LONG_RUNNING_FLAG" ]; then
        qlog_warn "TIER 2 SKIPPED: long-running AT command active"
        return 1
    fi

    qlog_info "TIER 2: Toggling radio (AT+CFUN=0/1)"
    append_event "watchcat_recovery" "Watchcat: toggling radio (Tier 2)" "warning"

    touch "$RECOVERY_FLAG"

    local result
    result=$(qcmd 'AT+CFUN=0' 2>/dev/null)
    if [ $? -ne 0 ]; then
        qlog_error "TIER 2: AT+CFUN=0 failed"
        return 0  # action attempted, enter cooldown
    fi

    sleep 3

    qcmd 'AT+CFUN=1' >/dev/null 2>&1
    wait_for_modem
    return 0
}

execute_tier3() {
    # Pre-check: backup SIM configured
    if [ -z "$CFG_BACKUP_SIM_SLOT" ]; then
        qlog_warn "TIER 3 SKIPPED: no backup SIM slot configured"
        return 1
    fi

    # Read current SIM slot
    local current_slot_raw
    local current_slot
    current_slot_raw=$(qcmd 'AT+QUIMSLOT?' 2>/dev/null)
    current_slot=$(printf '%s' "$current_slot_raw" | grep '+QUIMSLOT:' | sed 's/.*: *//' | tr -d '\r ')

    if [ -z "$current_slot" ]; then
        qlog_error "TIER 3: Cannot read current SIM slot"
        return 1
    fi

    if [ "$CFG_BACKUP_SIM_SLOT" = "$current_slot" ]; then
        qlog_warn "TIER 3 SKIPPED: backup slot ($CFG_BACKUP_SIM_SLOT) equals current slot ($current_slot)"
        return 1
    fi

    qlog_info "TIER 3: SIM failover from slot $current_slot to slot $CFG_BACKUP_SIM_SLOT"
    append_event "sim_failover" "Watchcat: switching to SIM slot $CFG_BACKUP_SIM_SLOT (Tier 3)" "warning"

    touch "$RECOVERY_FLAG"

    # Save original slot for potential fallback
    original_sim_slot="$current_slot"

    # Stop tower failover daemon (locks are meaningless on different SIM)
    /etc/init.d/qmanager_tower_failover stop 2>/dev/null

    # Golden Rule SIM swap sequence: CFUN=0 → 2s → QUIMSLOT → 2s → CFUN=1
    local result
    result=$(qcmd 'AT+CFUN=0' 2>/dev/null)
    if [ $? -ne 0 ]; then
        qlog_error "TIER 3: AT+CFUN=0 failed, aborting SIM failover"
        /etc/init.d/qmanager_tower_failover start 2>/dev/null
        return 0  # action attempted
    fi

    sleep 2

    qcmd "AT+QUIMSLOT=$CFG_BACKUP_SIM_SLOT" >/dev/null 2>&1
    sleep 2
    qcmd 'AT+CFUN=1' >/dev/null 2>&1

    # Wait for modem to come back
    if ! wait_for_modem; then
        qlog_error "TIER 3: Modem unresponsive after SIM switch, falling back"
        sim_failover_fallback
        return 0
    fi

    # Verify SIM presence
    local cpin_result
    cpin_result=$(qcmd 'AT+CPIN?' 2>/dev/null)
    if printf '%s' "$cpin_result" | grep -q 'ERROR'; then
        qlog_error "TIER 3: No SIM in backup slot $CFG_BACKUP_SIM_SLOT, falling back"
        sim_failover_fallback
        return 0
    fi

    # Read new ICCID for logging
    local new_iccid_raw
    local new_iccid
    local iccid_suffix
    new_iccid_raw=$(qcmd 'AT+QCCID' 2>/dev/null)
    new_iccid=$(printf '%s' "$new_iccid_raw" | grep '+QCCID:' | sed 's/+QCCID: //g' | tr -d '\r ')
    iccid_suffix=$(printf '%s' "$new_iccid" | tail -c 4)

    current_sim_slot="$CFG_BACKUP_SIM_SLOT"
    qlog_info "TIER 3: Switched to slot $CFG_BACKUP_SIM_SLOT (ICCID: ...$iccid_suffix)"

    # Don't write SIM failover state yet — wait for cooldown to verify connectivity
    # The cooldown handler will check reachability and finalize
    return 0
}

# Fallback: revert SIM to original slot
sim_failover_fallback() {
    qlog_warn "SIM failover fallback: reverting to slot $original_sim_slot"
    append_event "sim_failover" "Watchcat: backup SIM failed, reverting to slot $original_sim_slot" "warning"

    # Golden Rule sequence back to original
    qcmd 'AT+CFUN=0' >/dev/null 2>&1
    sleep 2
    qcmd "AT+QUIMSLOT=$original_sim_slot" >/dev/null 2>&1
    sleep 2
    qcmd 'AT+CFUN=1' >/dev/null 2>&1

    if ! wait_for_modem; then
        qlog_error "SIM revert: modem unresponsive after CFUN=1, skipping profile auto-apply"
        append_event "sim_failover" "Watchcat: SIM reverted but modem unresponsive — manual check needed" "error"
        # Slot command was sent; record the intended state. Tower failover daemon
        # will be (re)started by the next normal recovery cycle if modem recovers.
        current_sim_slot="$original_sim_slot"
        sim_failover_active="false"
        original_sim_slot="null"
        return
    fi

    # Auto-apply profile matching reverted SIM (watchdog_revert)
    local _rv_iccid_raw
    local _rv_iccid
    local _try
    _rv_iccid=""
    for _try in 1 2 3; do
        _rv_iccid_raw=$(qcmd 'AT+QCCID' 2>/dev/null)
        _rv_iccid=$(printf '%s' "$_rv_iccid_raw" | grep '+QCCID:' | sed 's/+QCCID: //g' | tr -d '\r ')
        [ -n "$_rv_iccid" ] && break
        sleep 1
    done
    # Mark the reverted SIM as known so the poller's boot-time swap
    # detector doesn't false-fire on the next reboot.
    if [ -n "$_rv_iccid" ]; then
        sim_db_add "$_rv_iccid"
    fi

    if [ -n "$_rv_iccid" ]; then
        ( . /usr/lib/qmanager/profile_mgr.sh && auto_apply_profile "$_rv_iccid" "watchdog_revert" )
    else
        qlog_info "[watchdog_revert] ICCID query failed after revert, skipping auto-apply"
    fi

    # Restart tower failover daemon
    /etc/init.d/qmanager_tower_failover start 2>/dev/null

    current_sim_slot="$original_sim_slot"
    sim_failover_active="false"
    original_sim_slot="null"
}

execute_tier4() {
    # Token bucket check
    count_recent_reboots
    if [ "$reboots_this_hour" -ge "$CFG_MAX_REBOOTS_PER_HOUR" ]; then
        qlog_error "TIER 4: Reboot limit reached (${reboots_this_hour}/${CFG_MAX_REBOOTS_PER_HOUR} per hour)"
        qlog_error "TIER 4: Auto-disabling watchcat"
        append_event "watchcat_recovery" "Watchcat disabled: reboot limit exceeded (${reboots_this_hour} reboots/hour)" "error"

        # Permanently disable via UCI
        uci set quecmanager.watchcat.enabled=0
        uci commit quecmanager 2>/dev/null

        CFG_ENABLED=0
        state="disabled"
        touch "$DISABLED_FLAG"
        write_state
        rm -f "$RECOVERY_FLAG"

        # Exit — procd won't respawn since UCI disabled
        exit 0
    fi

    qlog_error "TIER 4: System reboot (recovery ${reboots_this_hour}/${CFG_MAX_REBOOTS_PER_HOUR})"
    append_event "watchcat_recovery" "Watchcat: rebooting system (Tier 4)" "error"

    # Log reboot to crash.log (persists across reboots)
    local ts
    ts=$(date +%s)
    echo "${ts}|reboot|tier4_escalation" >> "$CRASH_LOG"

    # Trim crash.log to last 20 entries
    if [ -f "$CRASH_LOG" ]; then
        local count
        count=$(wc -l < "$CRASH_LOG" 2>/dev/null || echo 0)
        if [ "$count" -gt 20 ]; then
            tail -n 20 "$CRASH_LOG" > "${CRASH_LOG}.tmp"
            mv "${CRASH_LOG}.tmp" "$CRASH_LOG"
        fi
    fi

    last_recovery_time="$ts"
    last_recovery_tier=4
    total_recoveries=$((total_recoveries + 1))
    write_state
    rm -f "$RECOVERY_FLAG"

    # Reboot after flushing state
    ( sleep 1 && reboot ) &
    exit 0
}

# =============================================================================
# ESCALATION ENGINE
# =============================================================================

# Find the next enabled tier >= start_tier. Returns 0 if found (sets
# current_tier), 1 if no tiers left.
find_next_tier() {
    local start="$1"
    local t="$start"

    while [ "$t" -le 4 ]; do
        case "$t" in
            1) [ "$CFG_TIER1_ENABLED" = "1" ] && { current_tier="$t"; return 0; } ;;
            2) [ "$CFG_TIER2_ENABLED" = "1" ] && { current_tier="$t"; return 0; } ;;
            3) [ "$CFG_TIER3_ENABLED" = "1" ] && { current_tier="$t"; return 0; } ;;
            4) [ "$CFG_TIER4_ENABLED" = "1" ] && { current_tier="$t"; return 0; } ;;
        esac
        t=$((t + 1))
    done
    return 1  # no enabled tiers remaining
}

do_recovery() {
    local action_result=0

    qlog_info "RECOVERY: Executing Tier $current_tier (reason=$recovery_reason)"
    touch "$RECOVERY_FLAG"

    # Emit a single reason-tagged recovery-start marker before the per-tier
    # action events. The per-tier execute_* functions log their own tier-specific
    # detail; this one carries the TRIGGER REASON (unreachable vs quality) so the
    # activity feed can distinguish a reachability recovery from a quality one.
    # Suppressed on the recursive skip-to-next-tier path (only fires at entry).
    if [ "$_recovery_marker_emitted" != "$current_tier-$recovery_reason" ]; then
        _recovery_marker_emitted="$current_tier-$recovery_reason"
        if [ "$recovery_reason" = "quality" ]; then
            append_event "watchcat_recovery" "Watchcat: starting recovery (Tier $current_tier) — connection quality degraded" "warning"
        else
            append_event "watchcat_recovery" "Watchcat: starting recovery (Tier $current_tier) — internet unreachable" "warning"
        fi
    fi

    case "$current_tier" in
        1) execute_tier1; action_result=$? ;;
        2) execute_tier2; action_result=$? ;;
        3) execute_tier3; action_result=$? ;;
        4) execute_tier4; action_result=$? ;;  # may not return (reboot/exit)
    esac

    # If tier was skipped (returned 1), try next tier
    if [ "$action_result" -ne 0 ]; then
        qlog_info "Tier $current_tier skipped, trying next"
        if find_next_tier $((current_tier + 1)); then
            do_recovery  # recurse with next tier
        else
            qlog_error "No more enabled tiers — all recovery options exhausted"
            rm -f "$RECOVERY_FLAG"
            state="monitor"
            current_tier=0
            failure_counter=0
            _recovery_marker_emitted=""
        fi
        return
    fi

    # Recovery action executed — enter cooldown
    local ts
    ts=$(date +%s)
    last_recovery_time="$ts"
    last_recovery_tier="$current_tier"
    total_recoveries=$((total_recoveries + 1))
    cooldown_remaining="$CFG_COOLDOWN"
    state="cooldown"
    qlog_info "Entering COOLDOWN for ${CFG_COOLDOWN}s (after Tier $current_tier)"
}

# =============================================================================
# COOLDOWN COMPLETION
# =============================================================================

# Shared failure path for cooldown — fallback if Tier 3, then escalate.
_cooldown_handle_failure() {
    qlog_warn "COOLDOWN failure path entered for Tier $current_tier"

    # If Tier 3 failed to restore connectivity, fall back to original SIM
    if [ "$current_tier" -eq 3 ] && [ "$current_sim_slot" != "$original_sim_slot" ] && [ "$original_sim_slot" != "null" ]; then
        sim_failover_fallback
    fi

    # Escalate to the next enabled tier. Cooldown already verified the prior tier
    # did NOT restore the link/quality, so recovery must continue immediately.
    # current_tier is now the next tier; run it directly via do_recovery rather
    # than bouncing through suspect. The reachability path used to prime an
    # accumulator (failure_counter=CFG_MAX_FAILURES) to force the next suspect
    # cycle to re-breach; with the raw-streak model that prime is gone, and for
    # the quality path a suspect bounce would wrongly fall through to natural
    # recovery (link is reachable during quality degradation). Direct do_recovery
    # is correct and reason-agnostic.
    if find_next_tier $((current_tier + 1)); then
        qlog_info "Escalating to Tier $current_tier (reason=$recovery_reason)"
        append_event "watchcat_recovery" "Watchcat: recovery escalating to Tier $current_tier — previous tier did not restore the connection" "warning"
        state="recovery"
        do_recovery
    else
        qlog_error "All recovery tiers exhausted — returning to monitor"
        append_event "watchcat_recovery" "Watchcat: recovery exhausted — all enabled tiers tried, connection not restored" "error"
        state="monitor"
        current_tier=0
        failure_counter=0
        _recovery_marker_emitted=""
    fi
}

finish_cooldown() {
    rm -f "$RECOVERY_FLAG"

    # --- Reason-aware success criteria ---
    # A quality-triggered recovery cannot use reachability as the success
    # signal: a degraded-but-reachable link reports reachable the whole time,
    # so it would ALWAYS look "restored". Judge success from a FRESH quality
    # read against the configured ceilings instead.
    if [ "$recovery_reason" = "quality" ]; then
        if ! read_quality; then
            if [ "$cooldown_stale_retries" -lt 3 ]; then
                cooldown_stale_retries=$((cooldown_stale_retries + 1))
                qlog_warn "COOLDOWN(quality): status data stale (retry $cooldown_stale_retries/3) — extending by ${CFG_CHECK_INTERVAL}s"
                cooldown_remaining="$CFG_CHECK_INTERVAL"
                touch "$RECOVERY_FLAG"   # keep events suppressed during extension
                return
            fi
            qlog_error "COOLDOWN(quality): status data still stale after 3 retries — treating as recovery failure"
            cooldown_stale_retries=0
            _cooldown_handle_failure
            return
        fi
        cooldown_stale_retries=0

        if ! quality_breached; then
            qlog_info "COOLDOWN(quality) complete: quality RESTORED after Tier $current_tier"
            append_event "watchcat_recovery" "Watchcat: recovery succeeded (Tier $current_tier) — connection quality restored" "info"
            # Quality path never engages the Tier-3 SIM-failover finalization
            # block — that is only meaningful for the reachability path.
            state="monitor"
            current_tier=0
            failure_counter=0
            quality_breach_counter=0
            _recovery_marker_emitted=""
            return
        fi

        qlog_warn "COOLDOWN(quality) complete: quality STILL degraded after Tier $current_tier"
        _cooldown_handle_failure
        return
    fi

    # --- Reachability path (recovery_reason="unreachable") — unchanged ---
    # Try to read fresh ping data
    if ! read_ping; then
        if [ "$cooldown_stale_retries" -lt 3 ]; then
            cooldown_stale_retries=$((cooldown_stale_retries + 1))
            qlog_warn "COOLDOWN: ping data stale (retry $cooldown_stale_retries/3) — extending by ${CFG_CHECK_INTERVAL}s"
            cooldown_remaining="$CFG_CHECK_INTERVAL"
            touch "$RECOVERY_FLAG"   # keep events suppressed during extension
            return
        fi
        qlog_error "COOLDOWN: ping data still stale after 3 retries — treating as recovery failure"
        cooldown_stale_retries=0
        _cooldown_handle_failure
        return
    fi
    cooldown_stale_retries=0

    if [ "$ping_reachable" = "true" ]; then
        qlog_info "COOLDOWN complete: connectivity RESTORED after Tier $current_tier"
        append_event "watchcat_recovery" "Watchcat: recovery succeeded (Tier $current_tier) — internet connectivity restored" "info"

        # If this was Tier 3 SIM failover, finalize the failover state
        if [ "$current_tier" -eq 3 ] && [ "$current_sim_slot" != "$original_sim_slot" ] && [ "$original_sim_slot" != "null" ]; then
            sim_failover_active="true"

            # Read ICCID with 3×1s retry — matches sim_failover_fallback pattern
            local curr_iccid_raw
            local curr_iccid
            local _try
            curr_iccid=""
            for _try in 1 2 3; do
                curr_iccid_raw=$(qcmd 'AT+QCCID' 2>/dev/null)
                curr_iccid=$(printf '%s' "$curr_iccid_raw" | grep '+QCCID:' | sed 's/+QCCID: //g' | tr -d '\r ')
                [ -n "$curr_iccid" ] && break
                sleep 1
            done

            local ts
            ts=$(date +%s)
            jq -n -c \
                --argjson orig "$original_sim_slot" \
                --argjson curr "$current_sim_slot" \
                --argjson ts "$ts" \
                --arg iccid "$curr_iccid" \
                '{active:true, original_slot:$orig, current_slot:$curr, switched_at:$ts, reason:"connectivity_failure", original_iccid:"", current_iccid:$iccid}' \
                > "$SIM_FAILOVER_FILE"

            # Mark this failover SIM as known so the poller's boot-time SIM
            # swap detector treats it as expected (not a physical user swap).
            if [ -n "$curr_iccid" ]; then
                sim_db_add "$curr_iccid"
            fi

            qlog_info "SIM failover state saved: slot $original_sim_slot → $current_sim_slot"
            append_event "sim_failover" "Watchcat: SIM failover confirmed — running on slot $current_sim_slot" "info"

            # Auto-apply profile matching new SIM (watchdog)
            if [ -n "$curr_iccid" ]; then
                ( . /usr/lib/qmanager/profile_mgr.sh && auto_apply_profile "$curr_iccid" "watchdog" )
            fi
        fi

        # Reset — connectivity recovered
        state="monitor"
        current_tier=0
        failure_counter=0
        _recovery_marker_emitted=""
        return
    fi

    qlog_warn "COOLDOWN complete: connectivity NOT restored after Tier $current_tier"
    _cooldown_handle_failure
}

# =============================================================================
# USER-REQUESTED SIM REVERT
# =============================================================================

check_revert_request() {
    if [ -f "$REVERT_FLAG" ] && [ "$sim_failover_active" = "true" ]; then
        qlog_info "User requested SIM revert to slot $original_sim_slot"
        rm -f "$REVERT_FLAG"
        append_event "sim_failover" "Watchcat: reverting to original SIM slot $original_sim_slot (user request)" "info"

        touch "$RECOVERY_FLAG"
        sim_failover_fallback
        rm -f "$RECOVERY_FLAG" "$SIM_FAILOVER_FILE"

        sim_failover_active="false"
        state="monitor"
        current_tier=0
        failure_counter=0
        return 0
    fi
    rm -f "$REVERT_FLAG"  # clean up stale flag
    return 1
}

# =============================================================================
# MAIN LOOP
# =============================================================================

main() {
    # Prevent duplicate instances
    if [ -f "$PID_FILE" ]; then
        local old_pid
        old_pid=$(cat "$PID_FILE" 2>/dev/null)
        if [ -n "$old_pid" ] && kill -0 "$old_pid" 2>/dev/null; then
            qlog_error "Another watchcat already running (PID $old_pid), exiting"
            exit 1
        fi
        rm -f "$PID_FILE"
    fi
    echo $$ > "$PID_FILE"

    # Cleanup on exit
    trap 'rm -f "$PID_FILE" "$STATE_TMP" "$RECOVERY_FLAG"; write_state' EXIT INT TERM

    # Read configuration
    read_config

    if [ "$CFG_ENABLED" != "1" ]; then
        qlog_info "Watchcat disabled in config, exiting"
        exit 0
    fi

    qlog_info "========================================"
    qlog_info "QManager Watchcat starting (PID $$)"
    qlog_info "========================================"

    # Count reboots from crash.log (persisted across reboots)
    count_recent_reboots
    qlog_info "Reboots in last hour: $reboots_this_hour"

    # Check for stale SIM failover state from before reboot, verifying the
    # live slot matches what the file records. If the modem is on a
    # different slot than recorded, clear the file rather than carry stale
    # state forward.
    if [ -f "$SIM_FAILOVER_FILE" ]; then
        local sf_active_val
        sf_active_val=$(jq -r '(.active) | if . == null then "false" else tostring end' "$SIM_FAILOVER_FILE" 2>/dev/null)
        if [ "$sf_active_val" = "true" ]; then
            local _sf_orig
            local _sf_curr
            local _live_slot
            _sf_orig=$(jq -r '(.original_slot) | if . == null then "null" else tostring end' "$SIM_FAILOVER_FILE" 2>/dev/null)
            _sf_curr=$(jq -r '(.current_slot) | if . == null then "null" else tostring end' "$SIM_FAILOVER_FILE" 2>/dev/null)
            _live_slot=$(qcmd 'AT+QUIMSLOT?' 2>/dev/null | grep '+QUIMSLOT:' | sed 's/.*: *//' | tr -d '\r ')

            if [ -n "$_live_slot" ] && [ "$_live_slot" = "$_sf_curr" ]; then
                sim_failover_active="true"
                original_sim_slot="$_sf_orig"
                current_sim_slot="$_sf_curr"
                qlog_info "Resumed SIM failover state: slot $original_sim_slot → $current_sim_slot (verified)"
            else
                qlog_warn "SIM failover file recorded slot $_sf_curr but modem is on slot ${_live_slot:-unknown} — clearing stale state"
                rm -f "$SIM_FAILOVER_FILE"
            fi
        fi
    fi

    # Boot settle — let modem and other daemons stabilize
    qlog_info "Boot settle: waiting ${BOOT_SETTLE}s"
    write_state
    sleep "$BOOT_SETTLE"

    # --- Main monitoring loop ---
    while true; do
        # Check for config reload request. read_config re-resolves the SHARED
        # quality thresholds (quecmanager.quality_thresholds.*) too, so a change
        # to the shared degraded thresholds reaches the watchdog when the CGI
        # drops $RELOAD_FLAG. NOTE for Pass B: quality_thresholds.sh must drop
        # /tmp/qmanager_watchcat_reload (in addition to /tmp/qmanager_quality_reload
        # for the poller) so a live shared-threshold edit reaches the watchdog
        # without a full daemon restart. The watchdog deliberately does NOT consume
        # /tmp/qmanager_quality_reload itself — the poller owns that flag's deletion.
        if [ -f "$RELOAD_FLAG" ]; then
            rm -f "$RELOAD_FLAG"
            qlog_info "Config reload requested"
            read_config
            if [ "$CFG_ENABLED" != "1" ]; then
                qlog_info "Watchcat disabled via config reload, exiting"
                state="disabled"
                write_state
                exit 0
            fi
        fi

        # Check for user SIM revert request
        check_revert_request

        # --- LOCKED state check ---
        if check_locked; then
            if [ "$state" != "locked" ]; then
                qlog_info "Entering LOCKED state (maintenance)"
                state="locked"
                # If we were mid-recovery, clear the suppression flag so events resume.
                # Any active recovery is abandoned; the lock holder owns the modem.
                rm -f "$RECOVERY_FLAG"
                current_tier=0
                failure_counter=0
                cooldown_stale_retries=0
                quality_breach_counter=0
                _recovery_marker_emitted=""
                ssr_hold_clear
            fi
            write_state
            sleep "$CFG_CHECK_INTERVAL"
            continue
        fi

        # Exiting locked state
        if [ "$state" = "locked" ]; then
            qlog_info "Exiting LOCKED state"
            state="monitor"
            current_tier=0
            failure_counter=0
            cooldown_stale_retries=0
            quality_breach_counter=0
            _recovery_marker_emitted=""
            ssr_hold_clear
        fi

        # --- COOLDOWN state ---
        if [ "$state" = "cooldown" ]; then
            cooldown_remaining=$((cooldown_remaining - CFG_CHECK_INTERVAL))
            if [ "$cooldown_remaining" -le 0 ]; then
                cooldown_remaining=0
                finish_cooldown
            fi
            write_state
            sleep "$CFG_CHECK_INTERVAL"
            continue
        fi

        # --- Read ping data ---
        if ! read_ping; then
            # Stale or missing data — don't make recovery decisions
            write_state
            sleep "$CFG_CHECK_INTERVAL"
            continue
        fi

        # --- Sanitize the raw probe-failure streak from the ping daemon ---
        # A stale/garbage value must never crash the loop arithmetic; treat a
        # non-numeric streak as 0 (no failures observed this cycle).
        case "$ping_streak_fail" in ''|*[!0-9]*) ping_streak_fail=0 ;; esac
        # Mirror the raw streak into failure_counter purely for the state-file
        # readout (quality_breach_count stays separate). The recovery DECISION no
        # longer uses an accumulator — it compares the raw streak directly.
        failure_counter="$ping_streak_fail"

        # --- State machine ---
        case "$state" in
            monitor)
                if [ "$ping_streak_fail" -gt 0 ]; then
                    prev_state="$state"
                    state="suspect"
                    qlog_info "MONITOR → SUSPECT: streak_fail=$ping_streak_fail (threshold=$CFG_FAIL_THRESHOLD)"
                fi
                ;;

            suspect|ssr_hold)
                if [ "$ping_reachable" = "true" ] && [ "$ping_streak_fail" -eq 0 ]; then
                    # Naturally recovered (the expected SSR self-heal happy path)
                    qlog_info "SUSPECT → MONITOR: connectivity restored naturally"
                    state="monitor"
                    failure_counter=0
                    quality_breach_counter=0
                    _recovery_marker_emitted=""
                    ssr_hold_clear
                else
                    qlog_debug "SUSPECT: streak_fail=$ping_streak_fail/$CFG_FAIL_THRESHOLD"

                    # Breach is purely the RAW consecutive-probe streak crossing
                    # the threshold — no per-cycle accumulation (the ping daemon
                    # already debounces; double-counting here was the re-count bug).
                    if [ "$ping_streak_fail" -ge "$CFG_FAIL_THRESHOLD" ]; then
                        qlog_info "SUSPECT → RECOVERY: streak_fail=$ping_streak_fail >= $CFG_FAIL_THRESHOLD"
                        state="recovery"
                        recovery_reason="unreachable"

                        # Find first enabled tier
                        if [ "$current_tier" -eq 0 ]; then
                            find_next_tier 1
                        fi

                        # SSR-aware hold: if a recoverable baseband SSR is
                        # mid-flight, hold the ladder this cycle (leave
                        # current_tier as found above so fall-through after grace
                        # escalates exactly as today). continue re-evaluates next
                        # loop iteration.
                        if ssr_hold_gate; then
                            state="ssr_hold"
                            write_state
                            sleep "$CFG_CHECK_INTERVAL"
                            continue
                        fi

                        do_recovery
                    fi
                fi
                ;;

            recovery)
                # Should not stay here — do_recovery transitions to cooldown
                # If we're here, something went wrong
                qlog_warn "Unexpected RECOVERY state in main loop, resetting"
                state="monitor"
                failure_counter=0
                current_tier=0
                ;;
        esac

        # --- Quality-degradation trigger (independent of reachability) ---
        # Only when the reachability path did NOT already move us into
        # recovery/cooldown/ssr_hold this cycle. evaluate_quality runs the same
        # Tier ladder via do_recovery; if it triggers it sets state itself.
        # NOTE: ssr_hold is intentionally excluded (like recovery/cooldown) — do
        # NOT add it to this include-set, or quality would fire during a hold.
        if [ "$state" = "monitor" ] || [ "$state" = "suspect" ]; then
            evaluate_quality
        fi

        write_state
        sleep "$CFG_CHECK_INTERVAL"
    done
}

main "$@"
