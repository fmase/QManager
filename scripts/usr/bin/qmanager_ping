#!/bin/sh
# =============================================================================
# qmanager_ping — QManager Unified Ping Daemon
# =============================================================================
# The SINGLE source of internet reachability and latency data.
# All consumers (poller, watchcat, frontend) read from this daemon's output.
# This daemon NEVER touches the modem serial port.
#
# Probing is ICMP (BusyBox ping) — NOT HTTP. Each cycle probes IPv4 first
# (target_ipv4, default 1.1.1.1) and, only if that fails, falls back to IPv6
# (target_ipv6, default 2606:4700:4700::1111). A probe succeeds when a numeric
# round-trip time > 0 is parsed from the ping output ("round-trip
# min/avg/max = a/b/c", or a per-packet "time=" field). 100% packet loss yields
# no round-trip line, hence no rtt, hence a probe failure — the fail-safe.
#
# The v4-primary / v6-fallback ordering is the false-positive fix: on an
# IPv6-only bearer the v4 probe fails fast and the v6 probe succeeds, so
# `reachable` stays true. This replaces the previous curl/round-robin engine.
#
# Output: /tmp/qmanager_ping.json (atomic writes, slim — no stats/history)
# History: /tmp/qmanager_ping_history (flat-file ring buffer, read by poller)
#
# Stats (avg/min/max/jitter/loss) and history JSON array are computed by the
# poller in a single awk pass over the raw history file — not here.
#
# Consumers:
#   - Poller:   reads ping.json (reachability/streaks) + history file (stats)
#   - Watchcat: reads ping.json → streak_fail drives recovery decisions
#   - Frontend: reads via status.json (merged by poller)
#
# Install location: /usr/bin/qmanager_ping
# Dependencies: busybox ping, jq, awk, grep, cut, date, tail, mv
# =============================================================================

# --- Logging -----------------------------------------------------------------
. /usr/lib/qmanager/qlog.sh 2>/dev/null || {
    qlog_init() { :; }
    qlog_debug() { :; }
    qlog_info() { :; }
    qlog_warn() { :; }
    qlog_error() { :; }
    qlog_state_change() { :; }
}
qlog_init "ping"

# --- Configuration -----------------------------------------------------------
# Defaults — overridable via UCI (/etc/config/quecmanager, section ping_profile).
# These are fallbacks only; load_config() below re-reads UCI at startup and on
# every reload-flag trip. The active profile name drives interval + thresholds
# via resolve_profile(); the daemon holds the profile->params table as the
# single source of truth (UCI stores only the profile name + 2 ICMP targets).
PING_PROFILE="${PING_PROFILE:-relaxed}"
PING_TARGET_IPV4="${PING_TARGET_IPV4:-1.1.1.1}"
PING_TARGET_IPV6="${PING_TARGET_IPV6:-2606:4700:4700::1111}"
PING_INTERVAL="${PING_INTERVAL:-5}"
PING_INTERVAL_OVERRIDE=""    # quecmanager.ping_profile.interval_override (1–60); empty = unused
FAIL_THRESHOLD="${FAIL_THRESHOLD:-3}"
RECOVER_THRESHOLD="${RECOVER_THRESHOLD:-2}"
HISTORY_SIZE="${HISTORY_SIZE:-60}"
PROBE_COUNT=1              # ping -c : ICMP echo requests per probe
PROBE_TIMEOUT=2            # ping -W : per-probe wait (BusyBox: seconds)

# IPv6 ping invocation, detected once at startup via detect_ping6().
# Empty string = IPv6 probing unavailable on this build (v4-only fallback off).
PING6_CMD=""
PING6_WARNED=0             # warn-once guard for "IPv6 unavailable"

# --- File Paths --------------------------------------------------------------
CACHE_FILE="/tmp/qmanager_ping.json"
CACHE_TMP="/tmp/qmanager_ping.json.tmp"
HISTORY_FILE="/tmp/qmanager_ping_history"
RECOVERY_FLAG="/tmp/qmanager_recovery_active"
RELOAD_FLAG="/tmp/qmanager_ping_reload"
PID_FILE="/tmp/qmanager_ping.pid"

# --- State Variables ---------------------------------------------------------
streak_success=0
streak_fail=0
reachable="true"
prev_reachable="true"
last_family="none"     # ipv4 | ipv6 | none — which family answered last cycle
history_count=0        # tracked in shell — avoids wc -l fork every cycle

# =============================================================================
# HELPERS
# =============================================================================

# --- Ceil division: ceil(a/b) using POSIX integer math -----------------------
# samples = (secs + interval - 1) / interval. Both args must be positive ints.
ceil_div() {
    echo $(( ($1 + $2 - 1) / $2 ))
}

# --- Resolve the active profile name to {interval, fail/recover thresholds} ---
# Table (seconds): sensitive 1/6/3 · regular 2/10/6 · relaxed 5/15/10 · quiet
# 10/30/20. The daemon owns this table; UCI only stores the profile NAME.
# Thresholds are derived from seconds via ceil(secs/interval) so changing the
# interval keeps the time-to-fail / time-to-recover stable.
resolve_profile() {
    local _interval
    local _fail_secs
    local _recover_secs

    case "$PING_PROFILE" in
        sensitive) _interval=1;  _fail_secs=6;  _recover_secs=3  ;;
        regular)   _interval=2;  _fail_secs=10; _recover_secs=6  ;;
        quiet)     _interval=10; _fail_secs=30; _recover_secs=20 ;;
        relaxed|*)
            # Unknown/empty falls back to relaxed defaults.
            PING_PROFILE="relaxed"
            _interval=5;  _fail_secs=15; _recover_secs=10
            ;;
    esac

    # Fail/recover thresholds derive from the PROFILE's interval (time-to-fail /
    # time-to-recover stay stable per profile). The override only changes the
    # probe cadence — it deliberately does NOT re-derive the thresholds.
    FAIL_THRESHOLD=$(ceil_div "$_fail_secs" "$_interval")
    RECOVER_THRESHOLD=$(ceil_div "$_recover_secs" "$_interval")

    # Effective probe interval = interval_override ?? profile interval.
    # Override is validated 1–60 in load_config; empty/invalid = unused.
    if [ -n "$PING_INTERVAL_OVERRIDE" ]; then
        PING_INTERVAL="$PING_INTERVAL_OVERRIDE"
    else
        PING_INTERVAL="$_interval"
    fi
}

# --- Detect a working IPv6 ping invocation (called once at startup) ----------
# Prefer `ping -6` (modern BusyBox), then the `ping6` applet. Probe ::1 (loopback,
# always answerable when the kernel has IPv6) so detection never depends on the
# upstream bearer. Sets PING6_CMD; empty means IPv6 probing is unavailable.
detect_ping6() {
    if ping -6 -c 1 -W 1 ::1 >/dev/null 2>&1; then
        PING6_CMD="ping -6"
        return 0
    fi
    if command -v ping6 >/dev/null 2>&1 && ping6 -c 1 -W 1 ::1 >/dev/null 2>&1; then
        PING6_CMD="ping6"
        return 0
    fi
    PING6_CMD=""
    if [ "$PING6_WARNED" = "0" ]; then
        qlog_warn "IPv6 probing unavailable (no working ping -6 or ping6) — IPv4-only reachability"
        PING6_WARNED=1
    fi
    return 1
}

# --- Load configuration from UCI and re-resolve the profile ------------------
# Reads the profile name + the IPv4/IPv6 ICMP targets from quecmanager.ping_profile,
# falling back to the relaxed/Cloudflare defaults when a key is unset. The legacy
# target_1/target_2 keys (old HTTP URLs) are deliberately NOT read. Then resolves
# the profile to interval + thresholds. Safe to call at startup and on reload.
load_config() {
    local _profile
    local _t4
    local _t6
    local _override

    _profile=$(uci -q get quecmanager.ping_profile.profile 2>/dev/null)
    _t4=$(uci -q get quecmanager.ping_profile.target_ipv4 2>/dev/null)
    _t6=$(uci -q get quecmanager.ping_profile.target_ipv6 2>/dev/null)
    _override=$(uci -q get quecmanager.ping_profile.interval_override 2>/dev/null)

    [ -n "$_profile" ] && PING_PROFILE="$_profile"

    # Reset to the Cloudflare defaults first so a cleared UCI key reverts cleanly
    # on reload rather than sticking from a prior load.
    PING_TARGET_IPV4="1.1.1.1"
    PING_TARGET_IPV6="2606:4700:4700::1111"
    [ -n "$_t4" ] && PING_TARGET_IPV4="$_t4"
    [ -n "$_t6" ] && PING_TARGET_IPV6="$_t6"

    # interval_override: integer seconds 1–60, else treated as unused (empty).
    # Reset first so a cleared/invalid value reverts to the profile interval
    # live on reload rather than sticking from a prior load.
    PING_INTERVAL_OVERRIDE=""
    case "$_override" in
        ''|*[!0-9]*) ;;
        *) [ "$_override" -ge 1 ] && [ "$_override" -le 60 ] && PING_INTERVAL_OVERRIDE="$_override" ;;
    esac

    resolve_profile
}

# --- Execute a single ICMP probe against a target ----------------------------
# $1 = target host/literal, $2 = ping invocation ("ping", "ping -6", "ping6").
# Runs `$cmd -c 1 -W 2 <target>`. Parses the average RTT from the BusyBox
# summary line ("round-trip min/avg/max = X/Y/Z", avg = field 2), falling back
# to a per-packet "time=<n>" field. The rtt is formatted to 1 decimal via awk.
# SUCCESS only when a numeric rtt > 0 is extracted — 100% loss produces no
# round-trip line, so no rtt, so failure (the fail-safe). On success the rtt is
# echoed to stdout and 0 returned; otherwise 1.
do_ping_icmp() {
    local target="$1"
    local cmd="$2"
    local out
    local rtt

    # $cmd is an internal, fixed invocation token ("ping" / "ping -6" / "ping6")
    # — intentional word-split, not user input.
    # shellcheck disable=SC2086
    out=$($cmd -c "$PROBE_COUNT" -W "$PROBE_TIMEOUT" "$target" 2>/dev/null)

    # Preferred: average from the round-trip summary line (avg = 2nd of a/b/c).
    rtt=$(printf '%s\n' "$out" \
        | grep -oE 'min/avg/max[^=]*= [0-9.]+/[0-9.]+/[0-9.]+' \
        | grep -oE '[0-9.]+/[0-9.]+/[0-9.]+' \
        | cut -d'/' -f2)

    # Fallback: a per-packet "time=<n>" reading when no summary line is present.
    if [ -z "$rtt" ]; then
        rtt=$(printf '%s\n' "$out" \
            | grep -oE 'time=[0-9.]+' \
            | head -n1 \
            | cut -d'=' -f2)
    fi

    # Must be numeric (digits + optional dot).
    case "$rtt" in
        ''|*[!0-9.]*) return 1 ;;
    esac

    # Normalize to 1 decimal place; reject a non-positive / unparseable delta.
    rtt=$(awk -v r="$rtt" 'BEGIN { printf "%.1f", r }')
    case "$rtt" in
        ''|*[!0-9.]*) return 1 ;;
    esac
    awk -v r="$rtt" 'BEGIN { exit (r > 0) ? 0 : 1 }' || return 1

    echo "$rtt"
}

# --- Probe one cycle: IPv4 first, IPv6 fallback ------------------------------
# Publishes the winning rtt into the PROBE_RTT global and sets last_family
# ("ipv4"|"ipv6") on success, returning 0. On total failure clears PROBE_RTT,
# sets last_family="none", and returns 1. Results travel via globals (not
# stdout) so last_family persists into the main loop — a command-substitution
# subshell would discard it. IPv6 is attempted only when PING6_CMD is available
# and a v6 target is set; this either-family-up reachability is the fix for
# v6-only false positives.
PROBE_RTT=""
probe_cycle() {
    local rtt

    rtt=$(do_ping_icmp "$PING_TARGET_IPV4" "ping")
    if [ -n "$rtt" ]; then
        last_family="ipv4"
        PROBE_RTT="$rtt"
        return 0
    fi

    if [ -n "$PING6_CMD" ] && [ -n "$PING_TARGET_IPV6" ]; then
        rtt=$(do_ping_icmp "$PING_TARGET_IPV6" "$PING6_CMD")
        if [ -n "$rtt" ]; then
            last_family="ipv6"
            PROBE_RTT="$rtt"
            return 0
        fi
    fi

    last_family="none"
    PROBE_RTT=""
    return 1
}

# --- Write slim JSON cache atomically ----------------------------------------
# Keys: timestamp, mono, profile, targets, interval_sec, last_rtt_ms, reachable,
# streak_success, streak_fail, during_recovery, last_family. Stats (avg/min/max/
# jitter/loss) and the history array are computed by the poller, not here.
write_cache() {
    local rtt="$1"      # "34.2" or "null"

    local timestamp
    timestamp=$(date +%s)
    local mono
    mono=$(mono_now)

    local during_recovery="false"
    [ -f "$RECOVERY_FLAG" ] && during_recovery="true"

    jq -n \
        --argjson timestamp "$timestamp" \
        --argjson mono "$mono" \
        --arg profile "$PING_PROFILE" \
        --arg target4 "$PING_TARGET_IPV4" \
        --arg target6 "$PING_TARGET_IPV6" \
        --argjson interval "$PING_INTERVAL" \
        --argjson last_rtt "$rtt" \
        --argjson reachable "$reachable" \
        --argjson streak_s "$streak_success" \
        --argjson streak_f "$streak_fail" \
        --argjson during_rec "$during_recovery" \
        --arg last_family "$last_family" \
        '{
            timestamp: $timestamp,
            mono: $mono,
            profile: $profile,
            targets: [$target4, $target6],
            interval_sec: $interval,
            last_rtt_ms: $last_rtt,
            reachable: $reachable,
            streak_success: $streak_s,
            streak_fail: $streak_f,
            during_recovery: $during_rec,
            last_family: $last_family
        }' > "$CACHE_TMP"

    mv "$CACHE_TMP" "$CACHE_FILE"
}

# =============================================================================
# MAIN LOOP
# =============================================================================

main() {
    # Prevent duplicate instances
    if [ -f "$PID_FILE" ]; then
        local old_pid
        old_pid=$(cat "$PID_FILE" 2>/dev/null)
        if [ -n "$old_pid" ] && kill -0 "$old_pid" 2>/dev/null; then
            qlog_error "Another ping daemon already running (PID $old_pid), exiting"
            exit 1
        fi
        rm -f "$PID_FILE"
    fi
    echo $$ > "$PID_FILE"

    # Remove PID file on exit. BusyBox ash runs an INT/TERM trap handler but does
    # NOT exit afterward — without the explicit `exit`, a SIGTERM'd daemon deletes
    # its PID file via the trap yet keeps looping and writing stale JSON, so a
    # restart leaves a zombie until procd's SIGKILL fallback. The EXIT trap covers
    # the cleanup on every path; INT/TERM additionally force the exit.
    # (confirmed on RM551E 2026-06-26 — see docs/development/busybox-quirks.md)
    trap 'rm -f "$PID_FILE" "$CACHE_TMP"' EXIT
    trap 'rm -f "$PID_FILE" "$CACHE_TMP"; exit' INT TERM

    # Load profile + targets from UCI (resolves interval/thresholds), then detect
    # the IPv6 ping invocation once (cheap loopback probe).
    load_config
    detect_ping6

    qlog_info "========================================"
    qlog_info "QManager Ping Daemon starting (PID $$)"
    qlog_info "Profile: ${PING_PROFILE}"
    qlog_info "Targets: v4=${PING_TARGET_IPV4} v6=${PING_TARGET_IPV6}"
    qlog_info "IPv6 probe: ${PING6_CMD:-unavailable}"
    qlog_info "Interval: ${PING_INTERVAL}s${PING_INTERVAL_OVERRIDE:+ (override)}, Fail threshold: ${FAIL_THRESHOLD}, Recover threshold: ${RECOVER_THRESHOLD}"
    qlog_info "History size: ${HISTORY_SIZE}, Probe count: ${PROBE_COUNT}, Probe timeout: ${PROBE_TIMEOUT}s"
    qlog_info "========================================"

    # Clean up stale files from previous run
    rm -f "$CACHE_TMP"
    : > "$HISTORY_FILE"  # Start with empty history
    history_count=0

    while true; do
        # Live reload: re-read UCI (profile/targets/thresholds) within one
        # cycle when the CGI drops the flag, then clear it. No procd restart.
        if [ -f "$RELOAD_FLAG" ]; then
            load_config
            detect_ping6
            rm -f "$RELOAD_FLAG"
            qlog_info "Reloaded config: profile=${PING_PROFILE} interval=${PING_INTERVAL}s${PING_INTERVAL_OVERRIDE:+ (override)} fail=${FAIL_THRESHOLD} recover=${RECOVER_THRESHOLD} v4=${PING_TARGET_IPV4} v6=${PING_TARGET_IPV6} ping6=${PING6_CMD:-none}"
        fi

        local rtt
        if probe_cycle; then
            rtt="$PROBE_RTT"
        else
            rtt=""
        fi

        if [ -n "$rtt" ]; then
            # --- Ping succeeded ---
            streak_success=$((streak_success + 1))
            streak_fail=0

            qlog_debug "PING OK: family=${last_family} rtt=${rtt}ms (streak_success=${streak_success})"

            # Flip reachable back to true after sustained success
            if [ "$reachable" = "false" ] && [ "$streak_success" -ge "$RECOVER_THRESHOLD" ]; then
                prev_reachable="$reachable"
                reachable="true"
                qlog_state_change "reachable" "false" "true"
            fi

            # Append to history ring buffer
            echo "$rtt" >> "$HISTORY_FILE"
        else
            # --- Ping failed (both families) ---
            rtt="null"
            streak_fail=$((streak_fail + 1))
            streak_success=0

            qlog_debug "PING FAIL: both families unreachable (streak_fail=${streak_fail})"

            # Only mark unreachable after sustained failure
            if [ "$reachable" = "true" ] && [ "$streak_fail" -ge "$FAIL_THRESHOLD" ]; then
                prev_reachable="$reachable"
                reachable="false"
                qlog_state_change "reachable" "true" "false"
                qlog_warn "Internet unreachable after ${FAIL_THRESHOLD} consecutive failures"
            fi

            # Append null to history
            echo "null" >> "$HISTORY_FILE"
        fi

        # Trim history using shell counter (no wc -l fork)
        history_count=$((history_count + 1))
        if [ "$history_count" -gt "$HISTORY_SIZE" ]; then
            tail -n "$HISTORY_SIZE" "$HISTORY_FILE" > "${HISTORY_FILE}.tmp"
            mv "${HISTORY_FILE}.tmp" "$HISTORY_FILE"
            history_count=$HISTORY_SIZE
        fi

        # Write slim JSON cache
        write_cache "$rtt"

        sleep "$PING_INTERVAL"
    done
}

main "$@"
