#!/bin/sh
# =============================================================================
# qcmd — QManager Gatekeeper
# =============================================================================
# The SINGLE entry point for ALL modem communication.
# Uses flock to serialize access to the modem's serial port.
#
# Usage:
#   qcmd "AT+COMMAND"          → Execute AT command, return raw result
#   qcmd -j "AT+COMMAND"       → Execute AT command, return JSON-wrapped result
#
# Install location: /usr/bin/qcmd
# Dependencies: sms_tool, flock (busybox), timeout (busybox)
# =============================================================================

# --- Logging -----------------------------------------------------------------
. /usr/lib/qmanager/qlog.sh 2>/dev/null || {
    qlog_init() { :; }
    qlog_debug() { :; }
    qlog_info() { :; }
    qlog_warn() { :; }
    qlog_error() { :; }
    qlog_at_cmd() { :; }
    qlog_lock() { :; }
}
qlog_init "qcmd"

# --- Configuration -----------------------------------------------------------
LOCK_FILE="/var/lock/qmanager.lock"
LONG_FLAG="/tmp/qmanager_long_running"
PID_FILE="/var/lock/qmanager.pid"

SHORT_TIMEOUT=3        # seconds for normal AT commands
LONG_TIMEOUT=240       # seconds for AT+QSCAN and similar (passed to sms_tool -t)
LONG_SAFETY_TIMEOUT=260 # outer timeout safety net (20s beyond LONG_TIMEOUT)
LOCK_WAIT_SHORT=5      # seconds to wait for lock (normal commands)
LOCK_WAIT_LONG=10      # seconds to wait for lock (long commands)

# Ensure lock directory exists
mkdir -p /var/lock 2>/dev/null

# --- SMS tool device override (e.g. "-d /dev/smd7") -------------------------
SMS_TOOL_ARGS=""
_sms_dev=$(uci -q get quecmanager.settings.sms_tool_device 2>/dev/null)
[ -n "$_sms_dev" ] && SMS_TOOL_ARGS="-d $_sms_dev"

# --- Parse Arguments ---------------------------------------------------------
JSON_MODE=0
if [ "$1" = "-j" ]; then
    JSON_MODE=1
    shift
fi

COMMAND="$1"

if [ -z "$COMMAND" ]; then
    qlog_error "No command provided"
    echo '{"error":"no_command","detail":"Usage: qcmd [-j] \"AT+COMMAND\""}' >&2
    exit 1
fi

qlog_debug "Command received: ${COMMAND}"

# --- Helper: JSON Output -----------------------------------------------------
output_result() {
    local raw="$1"
    local err="$2"

    if [ "$JSON_MODE" -eq 1 ]; then
        if [ -n "$err" ]; then
            jq -n --arg error "$err" --arg command "$COMMAND" \
                '{success: false, error: $error, command: $command}'
        else
            jq -n --arg response "$raw" --arg command "$COMMAND" \
                '{success: true, response: $response, command: $command}'
        fi
    else
        if [ -n "$err" ]; then
            echo "ERROR: $err" >&2
            exit 1
        else
            echo "$raw"
        fi
    fi
}

# --- Helper: Command Classification -----------------------------------------
is_long_command() {
    local cmd="$1"

    if [ -f /etc/qmanager/long_commands.list ]; then
        while IFS= read -r pattern; do
            case "$pattern" in
                '#'*|'') continue ;;
            esac
            case "$cmd" in
                *"$pattern"*) return 0 ;;
            esac
        done < /etc/qmanager/long_commands.list
    fi

    case "$cmd" in
        *QSCAN*|*QSCANFREQ*|*QFOTADL*) return 0 ;;
        *) return 1 ;;
    esac
}

# --- Helper: Stale Lock Recovery ---------------------------------------------
check_stale_lock() {
    if [ -f "$PID_FILE" ]; then
        local old_pid
        old_pid=$(cat "$PID_FILE" 2>/dev/null)
        if [ -n "$old_pid" ] && ! kill -0 "$old_pid" 2>/dev/null; then
            qlog_lock "stale_recovery" "$old_pid"
            rm -f "$PID_FILE"
            return 0
        fi
    fi
    return 1
}

# --- Helper: flock with timeout ----------------------------------------------
# BusyBox flock does NOT support -w (wait with timeout).
# We implement it: try -n (non-blocking), retry with sleep until deadline.
#
# Usage: flock_wait <fd> <timeout_seconds>
# Returns: 0 = lock acquired, 1 = timed out
# -----------------------------------------------------------------------------
flock_wait() {
    local fd="$1"
    local wait_secs="$2"
    local elapsed=0

    while [ "$elapsed" -lt "$wait_secs" ]; do
        if flock -x -n "$fd" 2>/dev/null; then
            return 0
        fi
        sleep 1
        elapsed=$((elapsed + 1))
    done

    # One final try
    flock -x -n "$fd" 2>/dev/null
    return $?
}

# =============================================================================
# EXECUTION
#
# Uses subshell + FD 9 redirect: ( flock 9; ...; ) 9>"$LOCK_FILE"
# Lock is auto-released when the subshell exits.
# =============================================================================

if is_long_command "$COMMAND"; then
    # =========================================================================
    # LONG COMMAND PATH
    # =========================================================================
    qlog_info "Long command started: ${COMMAND}"
    echo "$COMMAND" > "$LONG_FLAG"

    result=$(
        (
            if ! flock_wait 9 "$LOCK_WAIT_LONG"; then
                exit 2
            fi
            echo $$ > "$PID_FILE"

            # Warm-up: flush residual serial buffer data + confirm modem responsive
            sms_tool $SMS_TOOL_ARGS at "AT" > /dev/null 2>&1 || { rm -f "$PID_FILE"; exit 3; }

            # Real command with explicit native timeout (sms_tool -t)
            # Outer timeout is a safety net in case sms_tool hangs
            timeout "$LONG_SAFETY_TIMEOUT" sms_tool $SMS_TOOL_ARGS -t "$LONG_TIMEOUT" at "$COMMAND" 2>/dev/null
            cmd_rc=$?
            rm -f "$PID_FILE"
            exit $cmd_rc
        ) 9>"$LOCK_FILE"
    )
    exit_code=$?

    rm -f "$LONG_FLAG"

    case $exit_code in
        0)
            qlog_info "Long command completed: ${COMMAND}"
            qlog_at_cmd "$COMMAND" "$result" "$exit_code"
            output_result "$result" ""
            ;;
        2)
            qlog_error "Lock acquisition failed for: ${COMMAND}"
            output_result "" "modem_busy"
            exit 1
            ;;
        3)
            qlog_error "Modem warm-up failed before: ${COMMAND}"
            output_result "" "modem_not_ready"
            exit 1
            ;;
        143)
            qlog_error "Long command killed by safety timeout: ${COMMAND}"
            output_result "" "command_timeout"
            exit 1
            ;;
        *)
            qlog_error "Long command failed: ${COMMAND} (sms_tool exit=${exit_code})"
            output_result "" "command_failed"
            exit 1
            ;;
    esac

elif [ -f "$LONG_FLAG" ]; then
    # =========================================================================
    # LONG COMMAND IN PROGRESS — Reject immediately
    # =========================================================================
    qlog_lock "blocked" "$(cat "$LONG_FLAG" 2>/dev/null)"
    output_result "" "scan_in_progress"
    exit 1

else
    # =========================================================================
    # SHORT COMMAND PATH
    # =========================================================================
    result=$(
        (
            if ! flock_wait 9 "$LOCK_WAIT_SHORT"; then
                exit 2
            fi
            echo $$ > "$PID_FILE"
            timeout "$SHORT_TIMEOUT" sms_tool $SMS_TOOL_ARGS at "$COMMAND" 2>/dev/null
            cmd_rc=$?
            rm -f "$PID_FILE"
            exit $cmd_rc
        ) 9>"$LOCK_FILE"
    )
    exit_code=$?

    # Lock failed — try stale recovery and retry once
    if [ $exit_code -eq 2 ]; then
        qlog_lock "timeout" "short command: ${COMMAND}"

        if check_stale_lock; then
            result=$(
                (
                    if ! flock_wait 9 2; then
                        exit 2
                    fi
                    echo $$ > "$PID_FILE"
                    timeout "$SHORT_TIMEOUT" sms_tool $SMS_TOOL_ARGS at "$COMMAND" 2>/dev/null
                    cmd_rc=$?
                    rm -f "$PID_FILE"
                    exit $cmd_rc
                ) 9>"$LOCK_FILE"
            )
            exit_code=$?
        fi

        if [ $exit_code -eq 2 ]; then
            qlog_error "Lock acquisition failed for: ${COMMAND}"
            output_result "" "modem_busy"
            exit 1
        fi
    fi

    qlog_at_cmd "$COMMAND" "$result" "$exit_code"

    if [ $exit_code -ne 0 ]; then
        qlog_error "Short command timeout: ${COMMAND} (exit=${exit_code})"
        output_result "" "command_timeout"
        exit 1
    fi

    output_result "$result" ""
fi
