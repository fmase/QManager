#!/bin/sh
# =============================================================================
# qmanager_scenario_schedule — Cron-Callable Connection Scenario Apply
# =============================================================================
# Called by cron at each schedule transition to apply a connection scenario
# (network mode + band locks) for the currently active SIM profile.
#
# Usage:
#   qmanager_scenario_schedule <scenarioId>
#
# The scenario id is baked into the cron line at install time. This worker
# resolves the scenario's config from disk (DISK is the single source of
# truth — see scenario_mgr.sh::scenario_resolve_config) and applies it.
#
# Self-heal guard: if no profile with schedule.enabled is active when this
# fires (e.g. the user deactivated the profile and teardown was missed), the
# worker tears down the stale scenario cron lines and exits without applying.
#
# scenario_apply is NON-REBOOT (mode_pref + band locks only).
#
# Dependencies: qcmd, qlog.sh, scenario_mgr.sh, profile_mgr.sh
# Install location: /usr/bin/qmanager_scenario_schedule
# =============================================================================

# --- Logging -----------------------------------------------------------------
. /usr/lib/qmanager/qlog.sh 2>/dev/null || {
    qlog_init() { :; }
    qlog_debug() { :; }
    qlog_info() { :; }
    qlog_warn() { :; }
    qlog_error() { :; }
}
qlog_init "scenario_schedule"

# --- Load libraries ----------------------------------------------------------
. /usr/lib/qmanager/scenario_mgr.sh 2>/dev/null
. /usr/lib/qmanager/profile_mgr.sh 2>/dev/null

# --- Validate arguments ------------------------------------------------------
TARGET="$1"

if [ -z "$TARGET" ]; then
    qlog_error "No scenario id provided"
    exit 1
fi

# --- Self-heal guard: only act for an active, schedule-enabled profile -------
ACTIVE_PROFILE=$(get_active_profile)
if [ -z "$ACTIVE_PROFILE" ] || \
   [ "$(scenario_profile_schedule_enabled "$ACTIVE_PROFILE")" != "true" ]; then
    qlog_warn "No active scheduled profile — tearing down stale scenario cron"
    scenario_teardown_cron
    exit 0
fi

# --- Fallback to profile default if the baked-in scenario was deleted --------
if ! scenario_is_known "$TARGET"; then
    qlog_warn "Scheduled scenario '$TARGET' no longer exists — falling back to default"
    TARGET=$(scenario_profile_block "$ACTIVE_PROFILE" | jq -r '.default // "balanced"' 2>/dev/null)
    [ -z "$TARGET" ] && TARGET="balanced"
    scenario_is_known "$TARGET" || TARGET="balanced"
fi

qlog_info "Scheduled scenario transition → '$TARGET' (profile $ACTIVE_PROFILE)"
scenario_apply "$TARGET"

exit 0
