#!/bin/sh
# =============================================================================
# qmanager_tower_failover — Persistent Tower Lock Failover Daemon
# =============================================================================
# Spawned by lock.sh or settings.sh (detached) after a tower lock operation
# when failover is enabled. Runs as a persistent daemon, continuously
# monitoring signal quality and automatically clearing locks if the signal
# degrades.
#
# Signal data is read from the poller's cached JSON at /tmp/qmanager_status.json
# (updated every 2s by qmanager_poller). This avoids AT command contention
# and duplicated parsing logic.
#
# Lifecycle:
#   1. Writes PID file for singleton tracking
#   2. Initial settle delay (allows modem to apply lock and reconnect)
#   3. Polling loop: reads RSRP from status cache every POLL_INTERVAL seconds
#   4. Tracks consecutive bad readings (signal below threshold)
#   5. If BAD_CHECK_LIMIT consecutive bad readings occur:
#      a. Clears both LTE and NR-SA tower locks
#      b. Updates config to disabled (preserves cell targets for re-enable)
#      c. Writes activation flag for the UI
#      d. Exits
#   6. Periodically validates locks are still active; exits if disabled externally
#
# Resilience:
#   - Missing/stale status cache does NOT count toward failover
#   - Modem unreachable (from poller) does NOT count toward failover
#   - Only verified bad signal readings increment the failure counter
#   - Any good reading resets the counter to 0
#   - Graceful SIGTERM handling (no false failover on kill)
#
# The daemon is killed and respawned by lock.sh on each new lock,
# so only the most recent lock operation is monitored.
#
# PID file:  /tmp/qmanager_tower_failover.pid
# Flag file: /tmp/qmanager_tower_failover (written on activation)
# Config:    /etc/qmanager/tower_lock.json (read for threshold)
# Cache:     /tmp/qmanager_status.json (read-only, for signal data)
#
# Dependencies: qlog.sh, tower_lock_mgr.sh, jq
# Install location: /usr/bin/qmanager_tower_failover
# =============================================================================

# --- Logging -----------------------------------------------------------------
. /usr/lib/qmanager/qlog.sh 2>/dev/null || {
    qlog_init() { :; }
    qlog_debug() { :; }
    qlog_info() { :; }
    qlog_warn() { :; }
    qlog_error() { :; }
}
qlog_init "tower_failover"

# --- Load library ------------------------------------------------------------
. /usr/lib/qmanager/tower_lock_mgr.sh 2>/dev/null

# --- Configuration -----------------------------------------------------------
PID_FILE="/tmp/qmanager_tower_failover.pid"
ACTIVATED_FLAG="/tmp/qmanager_tower_failover"
STATUS_CACHE="/tmp/qmanager_status.json"
SETTLE_DELAY=20       # seconds — cell lock disconnects modem for 3-5s, then reconnect
POLL_INTERVAL=20      # seconds between signal checks
BAD_CHECK_LIMIT=3     # consecutive bad readings before failover triggers
CONFIG_CHECK_EVERY=6  # check config every N cycles (avoid excessive flash reads)

# --- Graceful shutdown -------------------------------------------------------
should_exit=0

cleanup() {
    should_exit=1
    rm -f "$PID_FILE"
}
trap cleanup INT TERM

# Also clean PID on normal exit
trap 'rm -f "$PID_FILE"' EXIT

# --- Write PID file ----------------------------------------------------------
echo $$ > "$PID_FILE"

qlog_info "Tower failover daemon started (PID=$$), settling for ${SETTLE_DELAY}s"

# --- Initial settle delay ----------------------------------------------------
# Sleep in 1-second increments so SIGTERM is handled promptly
settle_count=0
while [ "$settle_count" -lt "$SETTLE_DELAY" ]; do
    [ "$should_exit" -eq 1 ] && exit 0
    sleep 1
    settle_count=$((settle_count + 1))
done

# --- Read threshold from config ----------------------------------------------
threshold=$(tower_config_get ".failover.threshold")
[ -z "$threshold" ] && threshold=20
qlog_info "Failover daemon active — polling every ${POLL_INTERVAL}s, threshold=${threshold}%, require ${BAD_CHECK_LIMIT} consecutive bad checks"

# =============================================================================
# MAIN POLLING LOOP
# =============================================================================
consecutive_bad=0
cycle_count=0

while true; do
    # --- Check for shutdown signal -------------------------------------------
    [ "$should_exit" -eq 1 ] && {
        qlog_info "Failover daemon received shutdown signal, exiting cleanly"
        exit 0
    }

    # --- Periodically validate lock is still active --------------------------
    cycle_count=$((cycle_count + 1))
    if [ $((cycle_count % CONFIG_CHECK_EVERY)) -eq 0 ]; then
        lte_enabled=$(tower_config_get ".lte.enabled")
        nr_enabled=$(tower_config_get ".nr_sa.enabled")

        if [ "$lte_enabled" != "true" ] && [ "$nr_enabled" != "true" ]; then
            qlog_info "No active tower locks in config — daemon exiting"
            exit 0
        fi

        # Re-read threshold in case it was changed via settings
        new_threshold=$(tower_config_get ".failover.threshold")
        if [ -n "$new_threshold" ] && [ "$new_threshold" != "$threshold" ]; then
            threshold="$new_threshold"
            qlog_info "Threshold updated to ${threshold}%"
        fi
    fi

    # --- Read signal from poller cache ---------------------------------------
    if [ ! -f "$STATUS_CACHE" ]; then
        qlog_debug "Status cache not found — poller may not be running, skipping cycle"

        poll_count=0
        while [ "$poll_count" -lt "$POLL_INTERVAL" ]; do
            [ "$should_exit" -eq 1 ] && exit 0
            sleep 1
            poll_count=$((poll_count + 1))
        done
        continue
    fi

    modem_ok=$(jq -r '.modem_reachable // false' "$STATUS_CACHE" 2>/dev/null)
    if [ "$modem_ok" != "true" ]; then
        qlog_debug "Modem unreachable (from poller cache) — skipping cycle"

        poll_count=0
        while [ "$poll_count" -lt "$POLL_INTERVAL" ]; do
            [ "$should_exit" -eq 1 ] && exit 0
            sleep 1
            poll_count=$((poll_count + 1))
        done
        continue
    fi

    # Read RSRP — prefer LTE, fall back to NR
    rsrp=$(jq -r '.lte.rsrp // empty' "$STATUS_CACHE" 2>/dev/null)
    if [ -z "$rsrp" ]; then
        rsrp=$(jq -r '.nr.rsrp // empty' "$STATUS_CACHE" 2>/dev/null)
    fi

    # Validate RSRP is a negative number (all valid RSRP values are < 0)
    case "$rsrp" in
        -[0-9]*) ;; # valid
        *) rsrp="" ;; # invalid — treat as no signal
    esac

    # --- Calculate signal quality --------------------------------------------
    if [ -z "$rsrp" ]; then
        quality=0
        qlog_debug "No valid RSRP in cache — signal quality = 0%"
    else
        quality=$(calc_signal_quality "$rsrp")
    fi

    # --- Evaluate signal quality ---------------------------------------------
    if [ "$quality" -lt "$threshold" ]; then
        consecutive_bad=$((consecutive_bad + 1))
        qlog_warn "Signal below threshold: quality=${quality}%, threshold=${threshold}%, consecutive_bad=${consecutive_bad}/${BAD_CHECK_LIMIT}"

        if [ "$consecutive_bad" -ge "$BAD_CHECK_LIMIT" ]; then
            qlog_warn "TOWER FAILOVER: ${BAD_CHECK_LIMIT} consecutive bad readings — clearing locks"

            # --- Execute failover -------------------------------------------
            unlock_ok=0

            # Clear LTE tower lock
            lte_result=$(tower_unlock_lte 2>/dev/null)
            case "$lte_result" in
                *ERROR*) qlog_error "FAILOVER: Failed to clear LTE lock: $lte_result" ;;
                *) unlock_ok=1; qlog_info "FAILOVER: LTE tower lock cleared" ;;
            esac

            sleep 0.2

            # Clear NR-SA tower lock
            nr_result=$(tower_unlock_nr 2>/dev/null)
            case "$nr_result" in
                *ERROR*) qlog_error "FAILOVER: Failed to clear NR lock: $nr_result" ;;
                *) unlock_ok=1; qlog_info "FAILOVER: NR-SA tower lock cleared" ;;
            esac

            if [ "$unlock_ok" -eq 1 ]; then
                # Update config — preserve cell targets, just disable locks
                tower_config_update '.lte.enabled = false | .nr_sa.enabled = false'

                # Write activation flag for UI
                echo "activated" > "$ACTIVATED_FLAG"
                qlog_warn "TOWER FAILOVER COMPLETE: Locks cleared, daemon exiting"
            else
                # Both unlock commands failed — retry once
                qlog_error "FAILOVER: Both unlock commands failed, retrying in 5s..."
                sleep 5

                retry_ok=0
                lte_retry=$(tower_unlock_lte 2>/dev/null)
                case "$lte_retry" in *ERROR*) ;; *) retry_ok=1 ;; esac
                sleep 0.2
                nr_retry=$(tower_unlock_nr 2>/dev/null)
                case "$nr_retry" in *ERROR*) ;; *) retry_ok=1 ;; esac

                if [ "$retry_ok" -eq 1 ]; then
                    tower_config_update '.lte.enabled = false | .nr_sa.enabled = false'
                    echo "activated" > "$ACTIVATED_FLAG"
                    qlog_warn "TOWER FAILOVER COMPLETE (retry succeeded): Locks cleared"
                else
                    qlog_error "TOWER FAILOVER FAILED: Could not clear locks after retry"
                    # Still exit — continuing to poll won't help if modem is unresponsive
                fi
            fi

            exit 0
        fi
    else
        # Good signal — reset counter
        if [ "$consecutive_bad" -gt 0 ]; then
            qlog_info "Signal recovered: quality=${quality}%, resetting bad counter (was ${consecutive_bad})"
        else
            qlog_debug "Signal OK: quality=${quality}% (RSRP=${rsrp:-n/a} dBm)"
        fi
        consecutive_bad=0
    fi

    # --- Sleep until next check (interruptible) ------------------------------
    poll_count=0
    while [ "$poll_count" -lt "$POLL_INTERVAL" ]; do
        [ "$should_exit" -eq 1 ] && exit 0
        sleep 1
        poll_count=$((poll_count + 1))
    done
done
