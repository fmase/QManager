#!/bin/sh
# =============================================================================
# qmanager_tower_schedule — Cron-Callable Tower Lock Apply/Clear
# =============================================================================
# Called by cron to automatically apply or clear tower locks on a schedule.
# Two modes:
#   qmanager_tower_schedule apply   — Read config, send lock AT commands
#   qmanager_tower_schedule clear   — Clear all tower locks
#
# On "apply", reads /etc/qmanager/tower_lock.json for cell targets and
# sends the appropriate AT+QNWLOCK commands. Also spawns the failover
# watcher if failover is enabled.
#
# On "clear", sends unlock commands for both LTE and NR-SA, and kills
# any running failover watcher.
#
# Dependencies: qcmd, qlog.sh, tower_lock_mgr.sh
# Install location: /usr/bin/qmanager_tower_schedule
# =============================================================================

# --- Logging -----------------------------------------------------------------
. /usr/lib/qmanager/qlog.sh 2>/dev/null || {
    qlog_init() { :; }
    qlog_debug() { :; }
    qlog_info() { :; }
    qlog_warn() { :; }
    qlog_error() { :; }
}
qlog_init "tower_schedule"

# --- Load library ------------------------------------------------------------
. /usr/lib/qmanager/tower_lock_mgr.sh 2>/dev/null

# --- Validate arguments ------------------------------------------------------
MODE="$1"

if [ "$MODE" != "apply" ] && [ "$MODE" != "clear" ]; then
    qlog_error "Invalid mode: $MODE (expected 'apply' or 'clear')"
    exit 1
fi

# =============================================================================
# APPLY MODE — Read config and send lock commands
# =============================================================================
if [ "$MODE" = "apply" ]; then
    qlog_info "Schedule APPLY triggered"

    tower_config_init

    if [ ! -f "$TOWER_CONFIG_FILE" ] || ! jq empty "$TOWER_CONFIG_FILE" 2>/dev/null; then
        qlog_error "Cannot read tower lock config"
        exit 1
    fi

    applied_any="false"

    # --- LTE Lock (using jq for all config parsing) ---
    lte_enabled=$(jq -r '.lte.enabled // false' "$TOWER_CONFIG_FILE" 2>/dev/null)

    if [ "$lte_enabled" != "true" ]; then
        qlog_info "Schedule: LTE locking disabled in config, skipping"
    else
        c1_earfcn=$(jq -r '.lte.cells[0].earfcn // empty' "$TOWER_CONFIG_FILE" 2>/dev/null)
        c1_pci=$(jq -r '.lte.cells[0].pci // empty' "$TOWER_CONFIG_FILE" 2>/dev/null)
        c2_earfcn=$(jq -r '.lte.cells[1].earfcn // empty' "$TOWER_CONFIG_FILE" 2>/dev/null)
        c2_pci=$(jq -r '.lte.cells[1].pci // empty' "$TOWER_CONFIG_FILE" 2>/dev/null)
        c3_earfcn=$(jq -r '.lte.cells[2].earfcn // empty' "$TOWER_CONFIG_FILE" 2>/dev/null)
        c3_pci=$(jq -r '.lte.cells[2].pci // empty' "$TOWER_CONFIG_FILE" 2>/dev/null)

        num_cells=0
        at_args=""
        if [ -n "$c1_earfcn" ] && [ -n "$c1_pci" ]; then
            num_cells=$((num_cells + 1))
            at_args="$c1_earfcn $c1_pci"
        fi
        if [ -n "$c2_earfcn" ] && [ -n "$c2_pci" ]; then
            num_cells=$((num_cells + 1))
            at_args="$at_args $c2_earfcn $c2_pci"
        fi
        if [ -n "$c3_earfcn" ] && [ -n "$c3_pci" ]; then
            num_cells=$((num_cells + 1))
            at_args="$at_args $c3_earfcn $c3_pci"
        fi

        if [ "$num_cells" -gt 0 ]; then
            qlog_info "Applying LTE lock: $num_cells cell(s)"
            result=$(tower_lock_lte "$num_cells" $at_args)
            case "$result" in
                *ERROR*)
                    qlog_error "Schedule: LTE lock failed: $result"
                    ;;
                *)
                    qlog_info "Schedule: LTE lock applied"
                    tower_config_update '.lte.enabled = true'
                    applied_any="true"
                    ;;
            esac
            sleep 0.2
        fi
    fi

    # --- NR-SA Lock (using jq for all config parsing) ---
    nr_sa_enabled=$(jq -r '.nr_sa.enabled // false' "$TOWER_CONFIG_FILE" 2>/dev/null)

    if [ "$nr_sa_enabled" != "true" ]; then
        qlog_info "Schedule: NR-SA locking disabled in config, skipping"
    else
        nr_pci=$(jq -r '.nr_sa.pci // empty' "$TOWER_CONFIG_FILE" 2>/dev/null)
        nr_arfcn=$(jq -r '.nr_sa.arfcn // empty' "$TOWER_CONFIG_FILE" 2>/dev/null)
        nr_scs=$(jq -r '.nr_sa.scs // empty' "$TOWER_CONFIG_FILE" 2>/dev/null)
        nr_band=$(jq -r '.nr_sa.band // empty' "$TOWER_CONFIG_FILE" 2>/dev/null)

        if [ -n "$nr_pci" ] && [ "$nr_pci" != "null" ] && \
           [ -n "$nr_arfcn" ] && [ "$nr_arfcn" != "null" ] && \
           [ -n "$nr_scs" ] && [ "$nr_scs" != "null" ] && \
           [ -n "$nr_band" ] && [ "$nr_band" != "null" ]; then
            qlog_info "Applying NR-SA lock: PCI=$nr_pci ARFCN=$nr_arfcn SCS=$nr_scs Band=$nr_band"
            result=$(tower_lock_nr "$nr_pci" "$nr_arfcn" "$nr_scs" "$nr_band")
            case "$result" in
                *ERROR*)
                    qlog_error "Schedule: NR-SA lock failed: $result"
                    ;;
                *)
                    qlog_info "Schedule: NR-SA lock applied"
                    tower_config_update '.nr_sa.enabled = true'
                    applied_any="true"
                    ;;
            esac
        fi
    fi

    # --- Spawn failover watcher if enabled and something was locked ---
    if [ "$applied_any" = "true" ]; then
        # Clear previous failover activation
        rm -f "$TOWER_FAILOVER_FLAG"
        tower_spawn_failover_watcher >/dev/null
    else
        qlog_info "Schedule: No locks applied (both lock types disabled or no targets configured)"
    fi

    qlog_info "Schedule APPLY complete"

# =============================================================================
# CLEAR MODE — Unlock all tower locks
# =============================================================================
elif [ "$MODE" = "clear" ]; then
    qlog_info "Schedule CLEAR triggered"

    # Clear LTE lock
    result=$(tower_unlock_lte 2>/dev/null)
    case "$result" in
        *ERROR*) qlog_error "Schedule: Failed to clear LTE lock: $result" ;;
        *) qlog_info "Schedule: LTE lock cleared" ;;
    esac

    sleep 0.2

    # Clear NR-SA lock
    result=$(tower_unlock_nr 2>/dev/null)
    case "$result" in
        *ERROR*) qlog_error "Schedule: Failed to clear NR lock: $result" ;;
        *) qlog_info "Schedule: NR-SA lock cleared" ;;
    esac

    # NOTE: We intentionally do NOT set lte.enabled / nr_sa.enabled to false
    # in the config. The schedule clear just unlocks the modem temporarily.
    # The enabled flags reflect the user's intent — if the user manually
    # disabled a lock type, the next schedule apply will respect that.
    # If the user left them enabled, the next apply will re-lock.

    # Kill any running failover watcher
    tower_kill_failover_watcher
    rm -f "$TOWER_FAILOVER_FLAG"

    qlog_info "Schedule CLEAR complete"
fi

exit 0
