#!/bin/sh
# qmanager_reset_password — CLI tool to reset the QManager web GUI password.
# Run this via SSH as root if you forget your QManager password.
# After running, visit the QManager web UI to set a new password.

AUTH_CONFIG="/etc/qmanager/auth.json"
SESSION_FILE="/tmp/qmanager_session.json"

if [ ! -f "$AUTH_CONFIG" ]; then
    echo "No QManager password is configured. Visit the web UI to set one."
    exit 0
fi

printf "This will remove the QManager web GUI password.\n"
printf "You will need to create a new password in the web interface.\n"
printf "Continue? [y/N] "
read -r answer

case "$answer" in
    y|Y|yes|YES)
        rm -f "$AUTH_CONFIG" "$SESSION_FILE"
        echo "QManager password has been reset."
        echo "Open the QManager web UI to set a new password."
        ;;
    *)
        echo "Cancelled."
        ;;
esac
