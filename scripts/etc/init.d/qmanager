#!/bin/sh /etc/rc.common
# =============================================================================
# qmanager — OpenWRT Init Script (procd)
# =============================================================================
# Manages all QManager daemon lifecycles:
#   1. qmanager_ping     — Unified ping daemon (internet reachability + latency)
#   2. qmanager_poller   — Modem data poller (AT commands + system metrics)
#   3. qmanager_watchcat  — Connection health watchdog (future)
#
# Each daemon runs as a separate procd instance with independent respawn.
# Startup order matters: ping → poller → watchcat
#
# Usage:
#   /etc/init.d/qmanager start|stop|restart|enable|disable
#
# Install location: /etc/init.d/qmanager
# =============================================================================

START=99
STOP=10
USE_PROCD=1

start_service() {
    # Ensure required directories exist
    mkdir -p /var/lock
    mkdir -p /etc/qmanager
    mkdir -p /usr/lib/qmanager

    # Ensure all /usr/bin scripts are executable
    for f in /usr/bin/qmanager_*; do
        [ -f "$f" ] && chmod +x "$f"
    done

    # Ensure all CGI scripts are executable
    for f in /www/cgi-bin/quecmanager/*.sh /www/cgi-bin/quecmanager/*/*.sh; do
        [ -f "$f" ] && chmod +x "$f"
    done

    # Create default long commands list if it doesn't exist
    if [ ! -f /etc/qmanager/long_commands.list ]; then
        cat > /etc/qmanager/long_commands.list << 'EOF'
# QManager Long Commands List
# Commands listed here will use extended timeouts and signal the poller to yield.
# One command keyword per line. Lines starting with # are comments.
QSCAN
QSCANFREQ
QFOTADL
EOF
    fi

    # Read log level from config (default: INFO)
    local log_level
    log_level=$(cat /etc/qmanager/log_level 2>/dev/null || echo "INFO")

    # -----------------------------------------------------------------
    # Instance 1: Ping Daemon (starts first — no dependencies)
    # -----------------------------------------------------------------
    procd_open_instance "ping"
    procd_set_param command /usr/bin/qmanager_ping
    procd_set_param env QLOG_LEVEL="$log_level"
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param respawn 3600 5 5
    procd_close_instance

    # -----------------------------------------------------------------
    # Instance 2: Poller Daemon (reads ping data for connectivity section)
    # -----------------------------------------------------------------
    procd_open_instance "poller"
    procd_set_param command /usr/bin/qmanager_poller
    procd_set_param env QLOG_LEVEL="$log_level"
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param respawn 3600 5 5
    procd_close_instance

    # -----------------------------------------------------------------
    # Instance 3: Watchcat Daemon (future — uncomment when implemented)
    # -----------------------------------------------------------------
    # procd_open_instance "watchcat"
    # procd_set_param command /usr/bin/qmanager_watchcat
    # procd_set_param env QLOG_LEVEL="$log_level"
    # procd_set_param stdout 1
    # procd_set_param stderr 1
    # procd_set_param respawn 3600 5 5
    # procd_close_instance

    # -----------------------------------------------------------------
    # Tower Failover Daemon (conditional — only if lock + failover active)
    # -----------------------------------------------------------------
    # Not a procd instance: the failover daemon is short-lived (exits after
    # failover triggers) and is managed via PID file by lock.sh/settings.sh.
    # We just need to spawn it on boot if a persisted lock + failover exists.
    if [ -f /etc/qmanager/tower_lock.json ]; then
        local _fo _lte _nr
        _fo=$(jq -r '.failover.enabled // false' /etc/qmanager/tower_lock.json 2>/dev/null)
        _lte=$(jq -r '.lte.enabled // false' /etc/qmanager/tower_lock.json 2>/dev/null)
        _nr=$(jq -r '.nr_sa.enabled // false' /etc/qmanager/tower_lock.json 2>/dev/null)
        if [ "$_fo" = "true" ] && { [ "$_lte" = "true" ] || [ "$_nr" = "true" ]; }; then
            setsid /usr/bin/qmanager_tower_failover >/dev/null 2>&1 &
            logger -t qmanager "Tower failover daemon spawned on boot (lock active + failover enabled)"
        fi
    fi
}

stop_service() {
    # Clean up state files
    rm -f /tmp/qmanager_long_running
    rm -f /var/lock/qmanager.pid
    rm -f /tmp/qmanager_recovery_active
    # Note: Ping cache and history are left for post-mortem debugging
    # Note: Logs in /tmp/qmanager.log are preserved for post-mortem debugging
}

service_triggers() {
    procd_add_reload_trigger "qmanager"
}
