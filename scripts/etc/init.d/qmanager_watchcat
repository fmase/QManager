#!/bin/sh /etc/rc.common
# =============================================================================
# qmanager_watchcat — Init Script for Connection Health Watchdog (procd)
# =============================================================================
# Manages the watchcat daemon lifecycle independently from the core qmanager
# service (poller, ping). This allows enabling/disabling the watchdog without
# disrupting critical monitoring services.
#
# Uses procd for automatic process tracking, respawn, and clean lifecycle.
#
# Usage:
#   /etc/init.d/qmanager_watchcat start|stop|restart|enable|disable
#
# Install location: /etc/init.d/qmanager_watchcat
# =============================================================================

START=99
STOP=10
USE_PROCD=1

start_service() {
    # Guard: check UCI enabled flag
    local enabled
    enabled=$(uci -q get quecmanager.watchcat.enabled 2>/dev/null)
    [ "$enabled" = "1" ] || return 0

    # Read log level from config
    local log_level
    log_level=$(cat /etc/qmanager/log_level 2>/dev/null || echo "INFO")

    procd_open_instance "watchcat"
    procd_set_param command /usr/bin/qmanager_watchcat
    procd_set_param env QLOG_LEVEL="$log_level"
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param respawn 3600 5 5
    procd_close_instance
}

stop_service() {
    # Clean up state files.
    # Note: /tmp/qmanager_watchcat.lock is intentionally NOT removed here.
    # install.sh touches it at the start of stop_services() as a maintenance
    # lock that must survive the entire install window — including the
    # procd-driven stop of this service. /tmp is tmpfs and clears on reboot
    # anyway, so there's nothing to clean up.
    rm -f /tmp/qmanager_watchcat.pid
    rm -f /tmp/qmanager_recovery_active
}

service_triggers() {
    procd_add_reload_trigger "quecmanager"
}
