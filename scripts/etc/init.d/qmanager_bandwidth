#!/bin/sh /etc/rc.common
# =============================================================================
# qmanager_bandwidth — Init Script for Live Bandwidth Monitor (procd)
# =============================================================================
# Manages the websocat WSS server and bridge_traffic_monitor_rm551 binary.
# UCI-gated: only starts if quecmanager.bridge_monitor.enabled=1.
#
# Instances:
#   1. websocat     — WSS broadcast server (port 8838 default)
#   2. bridge_monitor — ARM64 binary that reads interface stats and outputs JSON
#
# Usage:
#   /etc/init.d/qmanager_bandwidth start|stop|restart|enable|disable
#
# Install location: /etc/init.d/qmanager_bandwidth
# =============================================================================

START=99
STOP=10
USE_PROCD=1

SSL_CERT="/etc/qmanager/bandwidth_certs/ws.p12"

start_service() {
    # Guard: check UCI enabled flag
    local enabled
    enabled=$(uci -q get quecmanager.bridge_monitor.enabled 2>/dev/null)
    [ "$enabled" = "1" ] || return 0

    # Generate SSL certificate if missing
    /usr/bin/qmanager_bandwidth_ssl_setup

    # Generate config file from UCI values
    /usr/bin/qmanager_bandwidth_genconf

    # Ensure output directory exists
    mkdir -p /tmp/quecmanager

    # Read WebSocket port from UCI
    local ws_port
    ws_port=$(uci -q get quecmanager.bridge_monitor.ws_port 2>/dev/null)
    [ -z "$ws_port" ] && ws_port=8838

    # ─── Instance 1: websocat WSS broadcast server ──────────────────────
    procd_open_instance "websocat"
    procd_set_param command /usr/bin/websocat \
        -E -k -t \
        --pkcs12-der="$SSL_CERT" \
        --pkcs12-passwd "" \
        --ping-interval 10 \
        --ping-timeout 30 \
        "wss-listen:0.0.0.0:${ws_port}" \
        "broadcast:mirror:"
    procd_set_param respawn 3600 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance

    # ─── Instance 2: bridge traffic monitor binary ──────────────────────
    procd_open_instance "bridge_monitor"
    procd_set_param command /usr/bin/bridge_traffic_monitor_rm551
    procd_set_param respawn 3600 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

stop_service() {
    # Clean up runtime files
    rm -f /tmp/quecmanager/bridge_traffic_monitor
    rm -f /tmp/quecmanager/bridge_traffic_monitor.pid
}

service_triggers() {
    procd_add_reload_trigger "quecmanager"
}
